{
  "name": "sky-compiler",
  "version": "0.6.0",
  "description": "Sky programming language compiler",
  "type": "module",
  "bin": {
    "sky": "dist/bin/sky.js",
    "sky-lsp": "dist/bin/sky-lsp.js"
  },
  "scripts": {
    "build": "tsc",
    "bundle": "node ts-compiler/bin/build-binary.js",
    "dev": "tsx ts-compiler/cli.ts",
    "tokens": "node dist/cli.js tokens",
    "ast": "node dist/cli.js ast",
    "compile": "node dist/cli.js build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.0.0",
    "esbuild": "^0.27.4",
    "pkg": "^5.8.1",
    "tsx": "^4.7.0",
    "typescript": "^5.0.0",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "@types/express": "^5.0.6",
    "@types/react": "^19.2.14",
    "express": "^5.2.1",
    "js-yaml": "^4.1.1",
    "koa": "^3.1.2",
    "postject": "^1.0.0-alpha.6",
    "react": "^19.2.4",
    "smol-toml": "^1.6.0",
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-textdocument": "^1.0.12"
  },
  "imports": {
    "@sky/runtime/*": "./dist/runtime/*.js"
  }
}
