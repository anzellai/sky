module Main exposing (main)

import Sky.Core.Prelude exposing (..)
import Sky.Core.Task as Task
import Std.Db as Db
import Std.Auth as Auth
import Std.Log exposing (println)
import Sky.Core.Error as Error exposing (Error)


doTest db =
    case Task.run (Auth.register db "alice@example.com" "secret123") of

        Ok uid ->
            afterRegister db uid

        Err e ->
            println (errorToString e)


afterRegister db uid =
    case Task.run (Auth.login db "alice@example.com" "secret123") of

        Ok _user ->
            tryToken

        Err e ->
            println (errorToString e)


tryToken =
    case Auth.signToken "mysecret" { userId = 1 } 3600 of

        Ok tok ->
            verifyTok tok

        Err e ->
            println (errorToString e)


verifyTok tok =
    case Auth.verifyToken "mysecret" tok of

        Ok _claims ->
            println "auth ok"

        Err e ->
            println (errorToString e)


main =
    case Task.run (Db.open "sqlite" ":memory:") of

        Ok db ->
            doTest db

        Err e ->
            println (errorToString e)
