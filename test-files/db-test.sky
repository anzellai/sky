module Main exposing (main)

import Sky.Core.Prelude exposing (..)
import Sky.Core.List as List
import Sky.Core.String as String
import Sky.Core.Task as Task
import Std.Db as Db
import Std.Log exposing (println)
import Sky.Core.Error as Error exposing (Error)


runDb db =
    let
        _ =
            Task.run
                (Db.exec
                    db
                    "CREATE TABLE notes (id INTEGER PRIMARY KEY, text TEXT)"
                    [])
        _ = Task.run (Db.exec db "INSERT INTO notes (text) VALUES (?)" ["hello"])
        _ = Task.run (Db.exec db "INSERT INTO notes (text) VALUES (?)" ["world"])
    in
        queryAll db


queryAll db =
    case Task.run (Db.query db "SELECT text FROM notes ORDER BY id" []) of

        Ok rows ->
            printRows rows

        Err e ->
            println (errorToString e)


printRows rows =
    let
        n = List.length rows
        _ = println (String.fromInt n)
    in
        println "ok"


main =
    case Task.run (Db.open "sqlite" ":memory:") of

        Ok db ->
            runDb db

        Err e ->
            println (errorToString e)
