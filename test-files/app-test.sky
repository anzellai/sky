module Main exposing (main)

import Sky.Core.Prelude exposing (..)
import Sky.Core.String as String
import Sky.Core.List as List
import Std.Log exposing (println)

type Priority
    = High
    | Medium
    | Low

priorityLabel p =
    case p of
        High -> "HIGH"
        Medium -> "MED"
        Low -> "LOW"

main =
    let
        items =
            [ { name = "Fix bug", priority = High }
            , { name = "Write docs", priority = Low }
            , { name = "Add feature", priority = Medium }
            ]
        formatted = List.map (\item -> "[" ++ priorityLabel item.priority ++ "] " ++ item.name) items
    in
        println (String.join ", " formatted)
