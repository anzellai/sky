module Main exposing (main)

import Sky.Core.Prelude exposing (..)
import Sky.Core.String as String
import Std.Log exposing (println)


getName person =
    person.name


getAge person =
    person.age


main =
    let
        alice = { name = "Alice", age = 30 }
        _ = println (getName alice)
        bob = { alice | name = "Bob", age = 25 }
    in
        println (getName bob ++ " is " ++ String.fromInt (getAge bob))
