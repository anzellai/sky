module Main exposing (main)

import Sky.Core.Prelude exposing (..)
import Sky.Core.String as String
import Sky.Core.Result as Result
import Sky.Core.System as System
import Sky.Core.Task as Task
import Std.Log exposing (println)
import Sky.Core.Error as Error exposing (Error)


main =
    let
        _ = println (System.getenvOr "UNSET_VAR" "default-value")
        _ = println (String.fromInt (Result.withDefault 8080 (Task.run (System.getenvInt "PORT"))))
        _ =
            if Result.withDefault False (Task.run (System.getenvBool "DEBUG")) then
                println "debug on"

            else
                println "debug off"
        _ =
            case Task.run (System.getenv "HOME") of

                Ok v ->
                    println (String.append "HOME=" v)

                Err _ ->
                    println "no HOME"
    in
        println "env ok"
