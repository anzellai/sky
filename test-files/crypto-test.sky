module Main exposing (main)

import Sky.Core.Prelude exposing (..)
import Sky.Core.Crypto as Crypto
import Sky.Core.String as String
import Sky.Core.Task as Task
import Std.Log exposing (println)


afterToken tok =
    println (String.append "token: " tok)


main =
    let
        _ = println (Crypto.sha256 "hello")
        _ = println (Crypto.sha512 "hello")
        _ = println (Crypto.hmacSha256 "secret" "message")
        _ =
            if Crypto.constantTimeEqual "abc" "abc" then
                println "eq"

            else
                println "neq"
        _ =
            if Crypto.constantTimeEqual "abc" "abd" then
                println "eq"

            else
                println "neq"
    in
        case Task.perform (Crypto.randomToken 16) of

            Ok tok ->
                afterToken tok

            Err e ->
                println (errorToString e)
