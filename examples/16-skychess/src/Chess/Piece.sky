module Chess.Piece exposing (..)

import Sky.Core.Prelude exposing (..)

type alias Piece =
    { kind : Kind, colour : Colour }

type Colour
    = White
    | Black

type Kind
    = King
    | Queen
    | Rook
    | Bishop
    | Knight
    | Pawn


-- The `Piece` constructor (`Piece : Kind -> Colour -> Piece`) is
-- auto-generated from the type alias above (Sky v0.7.26+).
oppositeColour : Colour -> Colour
oppositeColour colour =
    case colour of

        White ->
            Black

        Black ->
            White


symbol : Kind -> Colour -> String
symbol kind colour =
    case colour of

        White ->
            whiteSymbol kind

        Black ->
            blackSymbol kind


whiteSymbol : Kind -> String
whiteSymbol kind =
    case kind of

        King ->
            "♔"

        Queen ->
            "♕"

        Rook ->
            "♖"

        Bishop ->
            "♗"

        Knight ->
            "♘"

        Pawn ->
            "♙"


blackSymbol : Kind -> String
blackSymbol kind =
    case kind of

        King ->
            "♚"

        Queen ->
            "♛"

        Rook ->
            "♜"

        Bishop ->
            "♝"

        Knight ->
            "♞"

        Pawn ->
            "♟"


materialValue : Kind -> Int
materialValue kind =
    case kind of

        Queen ->
            900

        Rook ->
            500

        Bishop ->
            330

        Knight ->
            320

        Pawn ->
            100

        King ->
            0


piecePrefix : Kind -> String
piecePrefix kind =
    case kind of

        King ->
            "K"

        Queen ->
            "Q"

        Rook ->
            "R"

        Bishop ->
            "B"

        Knight ->
            "N"

        Pawn ->
            ""
