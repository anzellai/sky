module Chess.Board exposing (..)

import Sky.Core.Prelude exposing (..)
import Sky.Core.Dict as Dict
import Sky.Core.Maybe as Maybe
import Sky.Core.List as List
import Sky.Core.String as String
import Chess.Piece exposing (..)

-- Square indexing: 0=a8, 1=b8, ..., 7=h8, 8=a7, ..., 63=h1
-- Row 0 = rank 8 (black back rank), Row 7 = rank 1 (white back rank)
getPiece : Int -> (Dict Int Piece) -> Maybe Piece
getPiece sq board = Dict.get sq board


setPiece : Int -> Piece -> (Dict Int Piece) -> Dict Int Piece
setPiece sq piece board = Dict.insert sq piece board


removePiece : Int -> (Dict Int Piece) -> Dict Int Piece
removePiece sq board = Dict.remove sq board


movePiece : Int -> Int -> (Dict Int Piece) -> Dict Int Piece
movePiece from to board =
    case Dict.get from board of

        Just piece ->
            Dict.insert to piece (Dict.remove from board)

        Nothing ->
            board


squareToFile : Int -> Int
squareToFile sq = modBy 8 sq


squareToRank : Int -> Int
squareToRank sq = 7 - (sq // 8)


fileRankToSquare : Int -> Int -> Int
fileRankToSquare file rank = (7 - rank) * 8 + file


squareToAlgebraic : Int -> String
squareToAlgebraic sq =
    let
        file = modBy 8 sq
        rank = 7 - (sq // 8)
        fileChar = fileToChar file
        rankChar = String.fromInt (rank + 1)
    in
        fileChar ++ rankChar


fileToChar : Int -> String
fileToChar f =
    if f == 0 then
        "a"

    else if f == 1 then
        "b"

    else if f == 2 then
        "c"

    else if f == 3 then
        "d"

    else if f == 4 then
        "e"

    else if f == 5 then
        "f"

    else if f == 6 then
        "g"

    else
        "h"


isOnBoard : Int -> Int -> Bool
isOnBoard row col = row >= 0 && row <= 7 && col >= 0 && col <= 7


findKing : Colour -> (Dict Int Piece) -> Int
findKing colour board = findKingLoop colour board allSquares


findKingLoop : Colour -> (Dict Int Piece) -> (List Int) -> Int
findKingLoop colour board squares =
    case squares of

        [] ->
            -1

        sq :: rest ->
            checkKingSquare sq colour board rest


checkKingSquare : Int -> Colour -> (Dict Int Piece) -> (List Int) -> Int
checkKingSquare sq colour board rest =
    case Dict.get sq board of

        Just piece ->
            if piece.kind == King && piece.colour == colour then
                sq

            else
                findKingLoop colour board rest

        Nothing ->
            findKingLoop colour board rest


allPiecesOfColour : Colour -> (Dict Int Piece) -> List (Int, Piece)
allPiecesOfColour colour board =
    List.filterMap (\sq -> checkSquareColour sq colour board) allSquares


checkSquareColour : Int -> Colour -> (Dict Int Piece) -> Maybe (Int, Piece)
checkSquareColour sq colour board =
    case Dict.get sq board of

        Just piece ->
            if piece.colour == colour then
                Just ( sq, piece )

            else
                Nothing

        Nothing ->
            Nothing


