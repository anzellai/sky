{
    "kind": "server",
    "port": 8000,
    "startupWaitMs": 2000,
    "steps": [
        {
            "name": "index",
            "method": "GET",
            "path": "/",
            "expectStatus": 200,
            "expectBodyContains": ["Sky Mux Server"]
        },
        {
            "name": "echo",
            "method": "GET",
            "path": "/echo",
            "expectStatus": 200,
            "expectBodyContains": ["echo"]
        },
        {
            "name": "ping",
            "method": "GET",
            "path": "/ping",
            "expectStatus": 200,
            "expectBodyContains": ["pong"]
        }
    ]
}
