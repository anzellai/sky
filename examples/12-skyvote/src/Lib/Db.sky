module Lib.Db exposing (exec, queryRows, getField)

import Sky.Core.Prelude exposing (..)
import Sky.Core.Maybe as Maybe
import Sky.Core.Dict as Dict
import Std.Db as Db

dbConn =
    case Db.open "sqlite" "skyvote.db" of
        
        Ok c ->
            c
        
        Err _ ->
            identity ""


exec queryStr args = Db.exec dbConn queryStr args


queryRows queryStr args = Db.query dbConn queryStr args


getField field row = Maybe.withDefault "" (Dict.get field row)
