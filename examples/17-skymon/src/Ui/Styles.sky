module Ui.Styles exposing (globalStyles)


globalStyles =
    String.join "\n"
        [ "*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }"
        , "body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; background: #0f172a; color: #e2e8f0; }"
        , ".app { max-width: 1200px; margin: 0 auto; padding: 0 24px; }"
        , ".header { background: #1e293b; border-bottom: 1px solid #334155; padding: 16px 0; margin-bottom: 24px; }"
        , ".header-inner { max-width: 1200px; margin: 0 auto; padding: 0 24px; display: flex; align-items: center; justify-content: space-between; }"
        , ".logo { font-size: 20px; font-weight: 700; color: #38bdf8; text-decoration: none; }"
        , ".nav { display: flex; gap: 16px; align-items: center; }"
        , ".nav-link { color: #94a3b8; text-decoration: none; font-size: 14px; }"
        , ".nav-link:hover { color: #e2e8f0; }"
        , ".user-info { display: flex; align-items: center; gap: 8px; font-size: 13px; color: #94a3b8; }"
        , ".avatar { width: 24px; height: 24px; border-radius: 50%; }"
        , ".section-title { font-size: 18px; font-weight: 600; margin-bottom: 16px; color: #f1f5f9; }"
        , ".grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 16px; margin-bottom: 32px; }"
        , ".card { background: #1e293b; border: 1px solid #334155; border-radius: 12px; padding: 20px; }"
        , ".card:hover { border-color: #475569; }"
        , ".card-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px; }"
        , ".card-title { font-size: 14px; font-weight: 600; color: #94a3b8; text-transform: uppercase; letter-spacing: 0.5px; }"
        , ".card-value { font-size: 36px; font-weight: 700; color: #f1f5f9; margin-bottom: 4px; }"
        , ".card-subtitle { font-size: 12px; color: #64748b; }"
        , ".status-dot { width: 10px; height: 10px; border-radius: 50%; display: inline-block; }"
        , ".status-healthy { background: #22c55e; }"
        , ".status-degraded { background: #eab308; }"
        , ".status-down { background: #ef4444; }"
        , ".status-unknown { background: #64748b; }"
        , ".monitor-card { cursor: pointer; }"
        , ".monitor-name { font-size: 16px; font-weight: 600; color: #f1f5f9; margin-bottom: 4px; }"
        , ".monitor-url { font-size: 12px; color: #64748b; word-break: break-all; }"
        , ".monitor-stats { display: flex; gap: 16px; margin-top: 12px; }"
        , ".monitor-stat { font-size: 13px; color: #94a3b8; }"
        , ".monitor-stat strong { color: #f1f5f9; }"
        , ".btn { padding: 8px 16px; border: none; border-radius: 8px; font-size: 14px; cursor: pointer; font-weight: 500; }"
        , ".btn-primary { background: #3b82f6; color: white; }"
        , ".btn-primary:hover { background: #2563eb; }"
        , ".btn-danger { background: #ef4444; color: white; }"
        , ".btn-danger:hover { background: #dc2626; }"
        , ".btn-ghost { background: transparent; color: #94a3b8; border: 1px solid #334155; }"
        , ".btn-ghost:hover { color: #e2e8f0; border-color: #475569; }"
        , ".btn-sm { padding: 4px 12px; font-size: 12px; }"
        , ".form-group { margin-bottom: 16px; }"
        , ".form-label { display: block; font-size: 13px; font-weight: 600; color: #94a3b8; margin-bottom: 6px; }"
        , ".form-input { width: 100%; padding: 10px 14px; border-radius: 8px; border: 1px solid #334155; font-size: 14px; background: #0f172a; color: #e2e8f0; }"
        , ".form-input:focus { border-color: #3b82f6; outline: none; }"
        , ".form-textarea { width: 100%; padding: 10px 14px; border-radius: 8px; border: 1px solid #334155; font-size: 13px; background: #0f172a; color: #e2e8f0; font-family: 'SF Mono', monospace; min-height: 80px; resize: vertical; }"
        , ".badge { display: inline-block; padding: 2px 8px; border-radius: 4px; font-size: 11px; font-weight: 600; text-transform: uppercase; }"
        , ".badge-public { background: #0f766e; color: #5eead4; }"
        , ".badge-user { background: #1d4ed8; color: #93c5fd; }"
        , ".badge-admin { background: #7c2d12; color: #fdba74; }"
        , ".sparkline { height: 40px; }"
        , ".table { width: 100%; border-collapse: collapse; }"
        , ".table th { text-align: left; padding: 8px 12px; font-size: 12px; color: #64748b; border-bottom: 1px solid #334155; }"
        , ".table td { padding: 8px 12px; font-size: 13px; border-bottom: 1px solid #1e293b; }"
        , ".empty-state { text-align: center; padding: 48px 24px; color: #64748b; }"
        , ".empty-state h3 { color: #94a3b8; margin-bottom: 8px; }"
        , ".notification { background: #1e40af; color: #bfdbfe; padding: 12px 16px; border-radius: 8px; margin-bottom: 16px; }"
        , ".status-page { max-width: 600px; margin: 0 auto; padding: 48px 24px; }"
        , ".status-header { text-align: center; margin-bottom: 32px; }"
        , ".status-all-good { color: #22c55e; font-size: 48px; margin-bottom: 8px; }"
        ]
