module Lib.Database exposing (conn, getField, getInt, getBool, exec, query, queryOrLog, execOrLog)

import Sky.Core.Prelude exposing (..)
import Sky.Core.Maybe as Maybe
import Sky.Core.Dict as Dict
import Sky.Core.Os as Os
import Sky.Core.Task as Task
import Std.Db as Db
import Std.Log exposing (println)
import Sky.Core.Error as Error exposing (Error(..), ErrorKind(..))


-- Db.* now returns Task Error a per the effect-boundary doctrine.
-- This Lib layer bridges through Task.run inside each wrapper so the
-- rest of skymon's update / view code keeps its existing Result
-- contracts unchanged. For long-running batched writes or background
-- reads, factor into a top-level Task and dispatch via Cmd.perform —
-- see 18-job-queue/src/Main.sky for the canonical async pattern.
conn =
    case Task.run (Db.open "sqlite" "skymon.db") of

        Ok c ->
            c

        Err e ->
            let
                _ =
                    println
                        ("[FATAL] Cannot open skymon.db: " ++ Error.toString e)
            in
                Os.exit 1


getField field row =
    Db.getField field row


getInt field row =
    Db.getInt field row


getBool field row =
    Db.getBool field row


-- Typed boundary: returns Result Error (). Callers in `update` MUST
-- pattern-match and decide what to do (log, notification, retry).
exec queryStr args =
    case Task.run (Db.exec conn queryStr args) of

        Ok _ ->
            Ok ()

        Err e ->
            Err e


-- Typed boundary: returns Result Error (List Row).
query queryStr args =
    Task.run (Db.query conn queryStr args)


-- Legacy logging fallback helpers. Prefer `query` / `exec` at update
-- boundaries; use these in view-helper contexts or fire-and-forget
-- sites where there's no model to update.
queryOrLog label queryStr args =
    case query queryStr args of

        Ok rows ->
            rows

        Err e ->
            let
                _ =
                    println ("[DB ERROR] " ++ label ++ ": " ++ Error.toString e)
            in
                []


execOrLog label queryStr args =
    case exec queryStr args of

        Ok _ ->
            ()

        Err e ->
            let
                _ =
                    println ("[DB ERROR] " ++ label ++ ": " ++ Error.toString e)
            in
                ()
