module Lib.Todo exposing (..)

-- Lib.Todo -- Todo display helpers.
import Sky.Core.Prelude exposing (..)
import Sky.Core.String as String
import Lib.Db as Db

showStatus done =
    if done == "1" then
        "[x]"
    else
        "[ ]"


formatTodo row =
    let
        todoId = Db.getField "id" row
        todoName = Db.getField "title" row
        todoDone = Db.getField "done" row
    in
        identity ("  " ++ todoId ++ ". " ++ showStatus todoDone ++ " " ++ todoName)
