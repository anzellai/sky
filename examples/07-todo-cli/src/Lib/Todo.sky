module Lib.Todo exposing (..)

-- Lib.Todo — Todo display helpers.
import Sky.Core.Prelude exposing (..)
import Sky.Core.String as String
import Lib.Db as Db

showStatus done =
    if done == "1" then
        "[x]"
    else
        "[ ]"


formatTodo row =
    let
        id = Db.getField "id" row
        title = Db.getField "title" row
        done = Db.getField "done" row
    in
        "  " ++ id ++ ". " ++ showStatus done ++ " " ++ title
