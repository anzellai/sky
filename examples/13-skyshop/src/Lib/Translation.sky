tCategory lang category =
    if lang == "zh" then
        case category of
            "Accessories" ->
                "配飾"
            
            "Bags" ->
                "包"
            
            "Fashion" ->
                "時尚"
            
            "Jewellery And Watches" ->
                "珠寶手錶"
            
            "Kids" ->
                "兒童"
            
            "Luxury Brands" ->
                "奢侈品"
            
            "Miscellaneous" ->
                "其他"
            
            "Wallet And Small Items" ->
                "錢包小物"
            
            _ ->
                category
    else
        category

tCartState lang state =
    if lang == "zh" then
        case state of
            "ongoing" ->
                "進行中"
            
            "pending" ->
                "待付款"
            
            "ordered" ->
                "已下訂單"
            
            "shipped" ->
                "已運送"
            
            "delivered" ->
                "已遞送"
            
            "cancelled" ->
                "已取消"
            
            "refunded" ->
                "已退款"
            
            _ ->
                state
    else
        case state of
            "ongoing" ->
                "Ongoing"
            
            "pending" ->
                "Pending"
            
            "ordered" ->
                "Ordered"
            
            "shipped" ->
                "Shipped"
            
            "delivered" ->
                "Delivered"
            
            "cancelled" ->
                "Cancelled"
            
            "refunded" ->
                "Refunded"
            
            _ ->
                state

tCurrency currency =
    case currency of
        "GBP" ->
            "British Pound"
        
        "HKD" ->
            "Hong Kong Dollar"
        
        "USD" ->
            "US Dollar"
        
        _ ->
            currency

tCurrencySymbol currency =
    case currency of
        "GBP" ->
            "£"
        
        "HKD" ->
            "HK$"
        
        "USD" ->
            "$"
        
        _ ->
            currency
