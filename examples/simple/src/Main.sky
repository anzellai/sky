module Main exposing (main)

import Net.Http as Http
import Sky.Core.Prelude exposing (..)
import Std.Log exposing (println)

main =
    let
        resp =
            Http.get "http://localhost:3000"
    in
        case resp of
            Ok r ->
                let
                    status =
                        Http.responseStatus r
                in
                    println "OK" status
            
            Err err ->
                println "Error" err
