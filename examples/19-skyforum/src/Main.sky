module Main exposing (main)

-- skyforum — a Reddit/HackerNews-style demo built with Sky.Live and
-- Std.Ui. The view layer is split across multiple modules
-- (State / Update / View.Common / View.Posts / View.Detail /
-- View.Compose / View.Login) so each per-module type-check stays
-- well below the heap-exhaustion limit (CLAUDE.md Limitation #17).
-- A single monolithic Main with the same surface OOMs the type-checker
-- and locked the Mac that birthed scripts/mem-guard.sh — the split
-- form gives us the full feature surface at zero ergonomics cost
-- pending compiler fix.

import Sky.Core.Prelude exposing (..)
import Std.Cmd as Cmd
import Std.Sub as Sub
import Std.Live exposing (app, route)
import Std.Ui as Ui
import Std.Ui exposing (Element)
import Std.Ui.Background as Background
import Std.Ui.Font as Font

import State exposing (..)
import Update exposing (update)
import View.Common exposing (topNav, pageFooter)
import View.Posts exposing (postsListView)
import View.Detail exposing (postDetailView)
import View.Login exposing (loginView)


-- ─── Init ────────────────────────────────────────────────────────

init : a -> ( Model, Cmd Msg )
init _req =
    let
        -- Seeds use record syntax (not positional Post/Comment ctors)
        -- because Sky's typed codegen can't yet infer that a bare `[]`
        -- in a constructor's typed-slice arg position should emit as
        -- `[]string{}` instead of `[]any{}` — record-literal syntax
        -- gives the codegen enough context (the field's type alias
        -- declares `upvoters : List String`) to pick the right shape.
        seedPosts =
            [ { id = 1, title = "Show SF: Sky.Ui — a typed elm-ui port for Sky.Live", url = "https://github.com/anzellai/sky", author = "alice", votes = 142, commentCount = 5, upvoters = [], downvoters = [] }
            , { id = 2, title = "Tiny CRDT primitives in 200 lines", url = "https://example.com/crdt", author = "bob", votes = 87, commentCount = 1, upvoters = [], downvoters = [] }
            , { id = 3, title = "Ask SF: Best resources for learning Hindley-Milner?", url = "https://example.com/hm", author = "carol", votes = 56, commentCount = 2, upvoters = [], downvoters = [] }
            , { id = 4, title = "Why server-driven UIs are having a moment", url = "https://example.com/server-ui", author = "dave", votes = 41, commentCount = 0, upvoters = [], downvoters = [] }
            , { id = 5, title = "Postgres tips that actually matter in production", url = "https://example.com/pg-tips", author = "eve", votes = 38, commentCount = 0, upvoters = [], downvoters = [] }
            ]
        seedComments =
            [ { id = 101, postId = 1, parentId = 0, author = "bob", body = "This looks great — does it support keyed children for diffing?", votes = 12, upvoters = [], downvoters = [] }
            , { id = 102, postId = 1, parentId = 101, author = "alice", body = "Yes, Std.Ui.Keyed handles that via the sky-key attribute.", votes = 9, upvoters = [], downvoters = [] }
            , { id = 103, postId = 1, parentId = 102, author = "bob", body = "Nice. Any plans for an actual stylesheet pass?", votes = 4, upvoters = [], downvoters = [] }
            , { id = 104, postId = 1, parentId = 0, author = "carol", body = "How does it compare to Phoenix LiveView?", votes = 7, upvoters = [], downvoters = [] }
            , { id = 105, postId = 1, parentId = 104, author = "alice", body = "Same idea: server holds state, browser is dumb.", votes = 11, upvoters = [], downvoters = [] }
            , { id = 201, postId = 2, parentId = 0, author = "alice", body = "Love seeing CRDT explanations that fit on one page.", votes = 5, upvoters = [], downvoters = [] }
            , { id = 301, postId = 3, parentId = 0, author = "dave", body = "Read 'Types and Programming Languages' (TAPL). Canonical reference.", votes = 18, upvoters = [], downvoters = [] }
            , { id = 302, postId = 3, parentId = 301, author = "carol", body = "Thanks. Anything shorter for a primer?", votes = 3, upvoters = [], downvoters = [] }
            ]
    in
        ( { posts = seedPosts
          , comments = seedComments
          , currentPage = HomePage
          , session = Nothing
          , loginError = ""
          , composeBody = ""
          , replyTo = 0
          , nextCommentId = 400
          }
        , Cmd.none
        )


-- ─── View dispatcher ─────────────────────────────────────────────

view : Model -> any
view model =
    Ui.layout []
        (Ui.column
            [ Ui.padding 24
            , Ui.spacing 24
            , Background.color (Ui.rgb 246 246 240)
            , Font.family "Verdana, Geneva, sans-serif"
            , Font.size 14
            , Font.color (Ui.rgb 33 33 33)
            ]
            [ topNav model
            , pageBody model
            , pageFooter
            ])


pageBody : Model -> Element Msg
pageBody model =
    case model.currentPage of
        HomePage ->
            postsListView model.session model.posts

        PostPage postId ->
            postDetailView model postId

        LoginPage ->
            loginView model


-- ─── App wiring ──────────────────────────────────────────────────

subscriptions : Model -> Sub.Sub Msg
subscriptions _ = Sub.none


main =
    app
        { init = init
        , update = update
        , view = view
        , subscriptions = subscriptions
        , routes = []
        , notFound = ()
        }
