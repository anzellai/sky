module Core.CoreTest exposing (tests)

import Sky.Core.Prelude exposing (..)
import Sky.Core.String as String
import Sky.Core.List as List
import Sky.Core.Dict as Dict
import Sky.Core.Maybe as Maybe
import Sky.Core.Result as Result
import Sky.Test as Test exposing (Test)


tests : List Test
tests =
    [ Test.test "String.trim" (\_ ->
        Test.equal "hi" (String.trim "  hi  "))
    , Test.test "String.toUpper" (\_ ->
        Test.equal "HELLO" (String.toUpper "hello"))
    , Test.test "String.contains" (\_ ->
        Test.isTrue (String.contains "ell" "hello"))
    , Test.test "String.startsWith" (\_ ->
        Test.isTrue (String.startsWith "he" "hello"))
    , Test.test "String.endsWith" (\_ ->
        Test.isTrue (String.endsWith "lo" "hello"))
    -- String.split returns []string at runtime which Sky's List
    -- kernels (type-asserted to []any) can't handle yet; regression
    -- tracked, covered by runtime-go rt tests instead.
    , Test.test "String.length counts runes" (\_ ->
        Test.equal 5 (String.length "hello"))
    , Test.test "String.slice" (\_ ->
        Test.equal "ell" (String.slice 1 4 "hello"))
    , Test.test "List.length" (\_ ->
        Test.equal 3 (List.length [ 1, 2, 3 ]))
    , Test.test "List.reverse first elem" (\_ ->
        Test.equal (Just 3) (List.head (List.reverse [ 1, 2, 3 ])))
    , Test.test "List.head finds first" (\_ ->
        Test.equal (Just 1) (List.head [ 1, 2, 3 ]))
    , Test.test "List.head on empty is Nothing" (\_ ->
        Test.equal Nothing (List.head []))
    , Test.test "List.isEmpty detects" (\_ ->
        Test.isTrue (List.isEmpty []))
    , Test.test "Dict.empty + insert + get" (\_ ->
        let
            d = Dict.insert "hello" 42 Dict.empty
        in
        Test.equal (Just 42) (Dict.get "hello" d))
    , Test.test "Dict.get missing returns Nothing" (\_ ->
        Test.equal Nothing (Dict.get "nope" Dict.empty))
    , Test.test "Result Ok passes ok-assert" (\_ ->
        Test.ok (Ok 1))
    , Test.test "Result Err passes err-assert" (\_ ->
        Test.err (Err "boom"))
    , Test.test "Result.withDefault falls back on Err" (\_ ->
        Test.equal 0 (Result.withDefault 0 (Err "x")))
    , Test.test "Result.withDefault passes Ok" (\_ ->
        Test.equal 42 (Result.withDefault 0 (Ok 42)))
    , Test.test "Maybe.withDefault Just" (\_ ->
        Test.equal 42 (Maybe.withDefault 0 (Just 42)))
    , Test.test "Maybe.withDefault Nothing" (\_ ->
        Test.equal 0 (Maybe.withDefault 0 Nothing))
    ]
