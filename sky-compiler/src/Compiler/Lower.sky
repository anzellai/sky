    name == "left" || name == "right" || name == "inner" || name == "source" ||
    name == "code" || name == "token" || name == "tokens" || name == "parts" ||
    name == "prefix" || name == "msg" || name == "key" || name == "val" ||
    name == "value" || name == "expr" || name == "span" || name == "type_" ||
    name == "scheme" || name == "entry" || name == "binding" || name == "branch" ||
    name == "variant" || name == "modName" || name == "filePath" || name == "outDir" ||
    name == "goCode" || name == "goPackage" || name == "goDecls" || name == "goArgs" ||
    name == "goCallee" || name == "goName" || name == "goMod" || name == "funcPart" ||
    name == "modPart" || name == "qualName" || name == "aliasMap" || name == "stdlibEnv" ||
    name == "depDecls" || name == "entryMod" || name == "loadedModules" ||
    name == "entryRegistry" || name == "entryCtx" || name == "baseCtx" ||
    name == "entryGoDecls" || name == "entryCtorDecls" || name == "helperDecls" ||
    name == "allDecls" || name == "rawGoCode" || name == "outPath" ||
