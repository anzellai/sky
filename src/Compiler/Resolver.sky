                  }
                )
                , ( "Task.sequence"
                , { quantified = [ 0 , 1 ]
                  , type_ =
                      TFun
                          (TApp (TConst "List") [ TApp (TConst "Task") [ TVar 0 (Just "err") , TVar 1 (Just "a") ] ])
                          (TApp (TConst "Task") [ TVar 0 (Just "err") , TApp (TConst "List") [ TVar 1 (Just "a") ] ])
                  }
                )
                ]
    in
        Env.union stdFunctions prelude
