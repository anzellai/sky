type alias ModuleGraph =
    { modules : List LoadedModule
    , order : List String
    , diagnostics : List String
    }


type alias LoadedModule =
    { name : String
    , qualifiedName : List String
    , filePath : String
    , ast : Module
    , checkResult : Maybe Checker.CheckResult
    }


resolveProject : String -> String -> Result String ModuleGraph
resolveProject entryPath srcRoot =
    case File.readFile entryPath of
        
        Err e ->
            Err ("Cannot read entry file: " ++ entryPath ++ " (" ++ e ++ ")")
        
        Ok source ->
            let
                lexResult = Lexer.lex source
            in
                case Parser.parse lexResult.tokens of
                    
                    Err e ->
                        Err ("Parse error in " ++ entryPath ++ ": " ++ e)
                    
                    Ok entryMod ->
                        let
                            entryName = String.join "." entryMod.name
                            entryLoaded =
                                { name = entryName
                                , qualifiedName = entryMod.name
                                , filePath = entryPath
                                , ast = entryMod
                                , checkResult = Nothing
                                }
                            resolveResult =
                                resolveImports srcRoot entryMod.imports
                                    [ entryLoaded ]
                                    Set.empty
                                    []
                            allModules = fst resolveResult
                            diags = snd resolveResult
                            order =
                                List.map (\m -> m.name)
                                    (List.reverse allModules)
                        in
                            Ok
                                { modules = List.reverse allModules
                                , order = order
                                , diagnostics = diags
                                }


resolveImports srcRoot imports loaded visited diagnostics =
    case imports of
        
        [] ->
            ( loaded, diagnostics )
        
        imp :: rest ->
            let
                modName = String.join "." imp.moduleName
            in
                if Set.member modName visited || isStdlib modName then
                    resolveImports srcRoot rest loaded visited diagnostics
                
                else if imp.alias_ == "_" then
                    resolveImports srcRoot rest loaded
                        (Set.insert modName visited)
                        diagnostics
                
                else
                    let
                        filePath = resolveModulePath srcRoot imp.moduleName
                    in
                        case File.readFile filePath of
                            
                            Err _ ->
                                let
                                    skyiPath = resolveBindingPath "." modName
                                in
                                    case File.readFile skyiPath of
                                        
                                        Ok skyiSource ->
                                            let
                                                skyiLexResult =
                                                    Lexer.lex skyiSource
                                            in
                                                case Parser.parse skyiLexResult.tokens of
                                                    
                                                    Ok skyiMod ->
                                                        let
                                                            loaded2 =
                                                                { name = modName
                                                                , qualifiedName =
                                                                    imp.moduleName
                                                                , filePath =
                                                                    skyiPath
                                                                , ast = skyiMod
                                                                , checkResult =
                                                                    Nothing
                                                                }
                                                        in
                                                            resolveImports
                                                                srcRoot
                                                                rest
                                                                (
                                                                loaded2 :: loaded
                                                                )
                                                                (
                                                                Set.insert
                                                                    modName
                                                                    visited
                                                                )
                                                                diagnostics
                                                    
                                                    Err e ->
                                                        resolveImports srcRoot
                                                            rest
                                                            loaded
                                                            (
                                                            Set.insert modName
                                                                visited
                                                            )
                                                            (
                                                            diagnostics
                                                                ++ [ "Parse error in binding "
                                                                    ++ modName
                                                                        ++ ": "
                                                                            ++ e
                                                                ]
                                                            )
                                                    
                                                    Err _ ->
                                                        resolveImports srcRoot
                                                            rest
                                                            loaded
                                                            (
                                                            Set.insert modName
                                                                visited
                                                            )
                                                            (
                                                            diagnostics
                                                                ++ [ "Module not found: "
                                                                    ++ modName
                                                                        ++ " (looked at "
                                                                            ++ filePath
                                                                                ++ " and "
                                                                                    ++ skyiPath
                                                                                        ++ ")"
                                                                ]
                                                            )
                                                    
                                                    Ok source ->
                                                        let
                                                            lexResult =
                                                                Lexer.lex source
                                                        in
                                                            case Parser.parse lexResult.tokens of
                                                                
                                                                Err e ->
                                                                    resolveImports
                                                                        srcRoot
                                                                        rest
                                                                        loaded
                                                                        (
                                                                        Set.insert
                                                                            modName
                                                                            visited
                                                                        )
                                                                        (
                                                                        diagnostics
                                                                            ++ [ "Parse error in "
                                                                                ++ modName
                                                                                    ++ ": "
                                                                                        ++ e
                                                                            ]
                                                                        )
                                                                
                                                                Ok modAst ->
                                                                    let
                                                                        newLoaded =
                                                                            { name =
                                                                                modName
                                                                            , qualifiedName =
                                                                                imp.moduleName
                                                                            , filePath =
                                                                                filePath
                                                                            , ast =
                                                                                modAst
                                                                            , checkResult =
                                                                                Nothing
                                                                            }
                                                                        newVisited =
                                                                            Set.insert
                                                                                modName
                                                                                visited
                                                                        depResult =
                                                                            resolveImports
                                                                                srcRoot
                                                                                modAst.imports
                                                                                (
                                                                                newLoaded :: loaded
                                                                                )
                                                                                newVisited
                                                                                diagnostics
                                                                    in
                                                                        resolveImports
                                                                            srcRoot
                                                                            rest
                                                                            (
                                                                            fst
                                                                                depResult
                                                                            )
                                                                            newVisited
                                                                            (
                                                                            snd
                                                                                depResult
                                                                            )


resolveModulePath : String -> (List String) -> String
resolveModulePath srcRoot parts =
    srcRoot ++ "/" ++ String.join "/" parts ++ ".sky"


resolveBindingPath : String -> String -> String
resolveBindingPath projectRoot modName =
    let
        pkgParts = String.split "." modName
        safeParts = List.map camelToUnderscore pkgParts
        safeName = String.join "_" safeParts
        prefix =
            if projectRoot == "." then
                ""
            
            else
                projectRoot ++ "/"
        primaryPath = prefix ++ ".skycache/go/" ++ safeName ++ "/bindings.skyi"
        altPath =
            prefix
                ++ ".skycache/go/"
                    ++ String.join "/" (List.map String.toLower pkgParts)
                        ++ "/bindings.skyi"
        cwdPrimary = ".skycache/go/" ++ safeName ++ "/bindings.skyi"
        cwdAlt =
            ".skycache/go/"
                ++ String.join "/" (List.map String.toLower pkgParts)
                    ++ "/bindings.skyi"
    in
        case File.readFile primaryPath of
            
            Ok _ ->
                primaryPath
            
            Err _ ->
                case File.readFile altPath of
                    
                    Ok _ ->
                        altPath
                    
                    Err _ ->
                        if projectRoot == "." then
                            altPath
                        
                        else
                            case File.readFile cwdPrimary of
                                
                                Ok _ ->
                                    cwdPrimary
                                
                                Err _ ->
                                    cwdAlt


camelToUnderscore : String -> String
camelToUnderscore s = String.toLower (camelInsertUnderscores s 0 "")


camelInsertUnderscores : String -> Int -> String -> String
camelInsertUnderscores s idx acc =
    if idx >= String.length s then
        acc
    
    else
        let
            ch = String.slice idx (idx + 1) s
            isUp =
                ch == "A"
                    || ch == "B"
                    || ch == "C"
                    || ch == "D"
                    || ch == "E"
                    || ch == "F"
                    || ch == "G"
                    || ch == "H"
                    || ch == "I"
                    || ch == "J"
                    || ch == "K"
                    || ch == "L"
                    || ch == "M"
                    || ch == "N"
                    || ch == "O"
                    || ch == "P"
                    || ch == "Q"
                    || ch == "R"
                    || ch == "S"
                    || ch == "T"
                    || ch == "U"
                    || ch == "V"
                    || ch == "W"
                    || ch == "X"
                    || ch == "Y"
                    || ch == "Z"
        in
            if isUp && idx > 0 then
                camelInsertUnderscores s (idx + 1) (acc ++ "_" ++ ch)
            
            else
                camelInsertUnderscores s (idx + 1) (acc ++ ch)


isStdlib : String -> Bool
isStdlib modName =
    String.startsWith "Sky.Core." modName
        || String.startsWith "Sky.Http." modName
        || modName == "Std.Db"
        || String.startsWith "Std." modName
        || modName == "Sky.Core.Prelude"
        || modName == "Sky.Interop"


