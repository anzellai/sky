lowerArgExpr : LowerCtx -> Expression -> GoExpr
lowerArgExpr ctx expr =
    case expr of
        IdentifierExpr name _ ->
            if not (String.isEmpty ctx.modulePrefix) && listContains name ctx.localFunctions then
                let
                    goName =
                        ctx.modulePrefix ++ "_" ++ capitalizeFirst (sanitizeGoIdent name)

                    fnArity =
                        getFnArity name ctx
                in
                    if fnArity > 1 then
                        makeCurryWrapper goName fnArity
                    else
                        lowerExpr ctx expr
            else
                lowerExpr ctx expr

        _ ->
            lowerExpr ctx expr


isZeroArityFn : String -> LowerCtx -> Bool
isZeroArityFn name ctx =
    case Dict.get name ctx.localFunctionArity of
        Just arity ->
            arity == 0

        Nothing ->
            False


getFnArity : String -> LowerCtx -> Int
getFnArity name ctx =
    case Dict.get name ctx.localFunctionArity of
        Just arity ->
            arity

        Nothing ->
            1


makeCurryWrapper : String -> Int -> GoExpr
makeCurryWrapper goName arity =
    if arity == 2 then
        GoRawExpr ("func(__ca0 any) any { return func(__ca1 any) any { return " ++ goName ++ "(__ca0, __ca1) } }")
    else if arity == 3 then
        GoRawExpr ("func(__ca0 any) any { return func(__ca1 any) any { return func(__ca2 any) any { return " ++ goName ++ "(__ca0, __ca1, __ca2) } } }")
    else if arity == 4 then
        GoRawExpr ("func(__ca0 any) any { return func(__ca1 any) any { return func(__ca2 any) any { return func(__ca3 any) any { return " ++ goName ++ "(__ca0, __ca1, __ca2, __ca3) } } } }")
    else
        GoIdent goName


listContains : String -> List String -> Bool
listContains needle haystack =
    List.foldl (\item acc -> if acc then True else item == needle) False haystack


isLocalFn : String -> Dict.Dict String Bool -> Bool
isLocalFn name fns =
    case Dict.get name fns of
        Just _ ->
            True

        Nothing ->
            False


isLocalFunction : String -> LowerCtx -> Bool
isLocalFunction name ctx =
    case Dict.get name ctx.localFunctionArity of
        Just _ ->
            True

        Nothing ->
            False


goQuote : String -> String
goQuote s =
    let
        escaped =
            String.replace "\"" "\\\"" (String.replace "\\" "\\\\" s)
    in
        "\"" ++ escaped ++ "\""


capitalizeFirst : String -> String
capitalizeFirst s =
    if String.isEmpty s then
        ""
    else
        String.toUpper (String.slice 0 1 s) ++ String.slice 1 (String.length s) s


lastPartOf : List String -> String
lastPartOf parts =
    case List.reverse parts of
        last :: _ ->
            last
        
        [] ->
            ""

            -- This should never happen if called correctly
listGet : Int -> List a -> a
listGet idx items =
    case List.head (List.drop idx items) of
        Just x ->
            x
        
        Nothing ->
            listGet 0 items

zipIndex : List a -> List (( Int, a ))
zipIndex items =
    zipIndexLoop 0 items

zipIndexLoop : Int -> List a -> List (( Int, a ))
zipIndexLoop idx items =
    case items of
        [] ->
            []
        
        x :: rest ->
            ( idx , x ) :: zipIndexLoop (idx + 1) rest

-- ══════════════════════════════════════════════════════
-- INLINE GO CODE EMISSION (for embedding in strings)
-- ══════════════════════════════════════════════════════
-- These produce Go code strings for embedding in IIFE bodies.
-- They duplicate some Emit.sky logic but operate on expressions directly.
emitGoExprInline : GoExpr -> String
emitGoExprInline expr =
    case expr of
        GoIdent name ->
            name
        
        GoBasicLit val ->
            val
        
        GoStringLit s ->
            "\"" ++ s ++ "\""
        
        GoCallExpr fn args ->
            let
                fnStr =
                    emitGoExprInline fn
                -- Add .(func(any) any) assertion if callee ends with ) — it's a function call
                calleeStr =
                    if String.endsWith ")" fnStr then
                        fnStr ++ ".(func(any) any)"
                    else
                        fnStr
            in
                calleeStr ++ "(" ++ String.join ", " (List.map emitGoExprInline args) ++ ")"
        
        GoSelectorExpr target sel ->
            emitGoExprInline target ++ "." ++ sel
        
        GoSliceLit items ->
            "[]any{" ++
            String.join ", " (List.map emitGoExprInline items) ++ "}"
        
        GoMapLit entries ->
            "map[string]any{" ++
            String.join ", " (List.map emitMapEntry entries) ++ "}"
        
        GoFuncLit params body ->
            "func(" ++
            String.join ", " (List.map emitInlineParam params) ++
            ") any { return " ++ emitGoExprInline body ++ " }"
        
        GoRawExpr code ->
            code
        
        GoCompositeLit typeName fields ->
            typeName ++
            "{" ++
            String.join ", "
                (List.map (\pair -> fst pair ++ ": " ++ emitGoExprInline (snd pair)) fields) ++
            "}"
        
        GoBinaryExpr op left right ->
            emitGoExprInline left ++ " " ++ op ++ " " ++ emitGoExprInline right
        
        GoUnaryExpr op operand ->
            op ++ emitGoExprInline operand
        
        GoIndexExpr target index ->
            emitGoExprInline target ++ "[" ++ emitGoExprInline index ++ "]"
        
        GoNilExpr ->
            "nil"

emitMapEntry : ( GoExpr, GoExpr ) -> String
emitMapEntry pair =
    let
        key =
            fst pair
        val =
            snd pair
    in
    emitGoExprInline key ++ ": " ++ emitGoExprInline val

emitInlineParam : GoParam -> String
emitInlineParam p =
    p.name ++ " " ++ p.type_

exprToGoString : LowerCtx -> Expression -> String
exprToGoString ctx expr =
    emitGoExprInline (lowerExpr ctx expr)

lowerExprToStmts : LowerCtx -> Expression -> List GoStmt
lowerExprToStmts ctx expr =
    [ GoExprStmt (lowerExpr ctx expr) ]

stmtsToGoString : List GoStmt -> String
stmtsToGoString stmts =
    let
        raw =
            String.join "; " (List.map stmtToGoString stmts)
    in
        fixCurriedCalls raw


fixCurriedCalls : String -> String
fixCurriedCalls code =
    code

stmtToGoString : GoStmt -> String
stmtToGoString stmt =
    case stmt of
        GoExprStmt expr ->
            emitGoExprInline expr
        
        GoAssign name expr ->
            name ++ " = " ++ emitGoExprInline expr
        
        GoShortDecl name expr ->
            name ++ " := " ++ emitGoExprInline expr
        
        GoReturn expr ->
            "return " ++ emitGoExprInline expr
        
        GoReturnVoid ->
            "return"
        
        GoIf cond thenBody elseBody ->
            "if " ++
            emitGoExprInline cond ++
            " { " ++
            stmtsToGoString thenBody ++
            " } else { " ++ stmtsToGoString elseBody ++ " }"
        
        GoBlock body ->
            stmtsToGoString body
