module Compiler.Lower exposing (..)

import Sky.Core.Prelude exposing (..)
import Sky.Core.Dict as Dict
import Sky.Core.Set as Set
import Sky.Core.List as List
import Sky.Core.String as String
import Compiler.Token exposing (emptySpan)
import Compiler.Ast as Ast exposing (..)
import Compiler.GoIr exposing (..)
import Compiler.Adt as Adt exposing (AdtRegistry)
import Compiler.Types exposing (Type, TFun, TConst, TVar, TApp, TTuple, TRecord, Scheme)
import Compiler.ParserCore as ParserCore
import Compiler.Resolver as Resolver

-- ══════════════════════════════════════════════════════
-- LOWERING CONTEXT
-- ══════════════════════════════════════════════════════
type alias LowerCtx =
    { registry : AdtRegistry
    , moduleExports : Dict.Dict String (Set.Set String)
    , importedConstructors : Dict.Dict String CtorInfo
    , localFunctions : List String
    , collectedImports : Set.Set String
    , importAliases : Dict.Dict String String
    , modulePrefix : String
    , localFunctionArity : Dict.Dict String Int
    , exposedStdlib : Dict.Dict String String
    , paramNames : Set.Set String
    }

type alias CtorInfo =
    { adtName : String , tagIndex : Int , arity : Int }

emptyCtx : LowerCtx
emptyCtx =
    { registry = Adt.emptyRegistry
    , moduleExports = Dict.empty
    , importedConstructors = Dict.empty
    , localFunctions = []
    , collectedImports = Set.empty
    , importAliases = Dict.empty
    , modulePrefix = ""
    , localFunctionArity = Dict.empty
    , exposedStdlib = Dict.empty
    , paramNames = Set.empty
    }


-- importAliases maps alias -> qualified module name
-- e.g. "Utils" -> "Lib.Utils" so that Utils.add → Lib_Utils_Add

-- ══════════════════════════════════════════════════════
-- MODULE LOWERING
-- ══════════════════════════════════════════════════════
-- Build exposedStdlib dict from module imports
buildExposedStdlib : List Ast.ImportDecl -> Dict.Dict String String
buildExposedStdlib imports =
    List.foldl
        (\imp acc ->
            let
                modName =
                    String.join "." imp.moduleName
            in
                let
                    names =
                        getExposedNames imp
                in
                    List.foldl (\n dict -> Dict.insert n modName dict) acc names
        )
        Dict.empty
        imports


getExposedNames : Ast.ImportDecl -> List String
getExposedNames imp =
    let
        modName =
            String.join "." imp.moduleName
    in
        case imp.exposing_ of
            ExposeAll ->
                Resolver.getStdlibExports modName

            ExposeList names ->
                -- Only expose the specifically listed names
                List.filter (\n -> listContains n (Resolver.getStdlibExports modName)) names

            ExposeNone ->
                []


lowerModule : AdtRegistry -> Module -> GoPackage
lowerModule registry mod =
    let
        exposed =
            buildExposedStdlib mod.imports
        ctx =
            { emptyCtx
            | registry = registry
            , localFunctions = collectLocalFunctions mod.declarations
            , importedConstructors = buildConstructorMap registry
            , exposedStdlib = exposed
            , localFunctionArity = collectLocalFunctionArities mod.declarations
            }

        -- Lower declarations
        goDecls =
            lowerDeclarations ctx mod.declarations

        -- Generate ADT constructor functions
        ctorDecls =
            generateConstructorDecls registry mod.declarations

        -- Collect needed imports
        imports =
            [ { path = "fmt" , alias_ = "" }
            , { path = "bufio" , alias_ = "" }
            , { path = "io" , alias_ = "" }
            , { path = "os" , alias_ = "" }
            , { path = "os/exec" , alias_ = "exec" }
            , { path = "net/http" , alias_ = "net_http" }
            , { path = "strconv" , alias_ = "" }
            , { path = "strings" , alias_ = "" }
            , { path = "sort" , alias_ = "" }
            , { path = "context" , alias_ = "" }
            , { path = "math" , alias_ = "" }
            , { path = "crypto/sha256" , alias_ = "crypto_sha256" }
            , { path = "crypto/md5" , alias_ = "crypto_md5" }
            , { path = "encoding/hex" , alias_ = "hex" }
            , { path = "encoding/base64" , alias_ = "base64" }
            , { path = "encoding/json" , alias_ = "encoding_json" }
            , { path = "time" , alias_ = "" }
            ]
        -- Generate inline helper functions
        helperDecls =
            generateHelperDecls
    in
        { name = "main"
        , imports = imports
        , declarations = List.concat [ helperDecls , ctorDecls , goDecls ]
        }

-- ══════════════════════════════════════════════════════
-- DECLARATION LOWERING
-- ══════════════════════════════════════════════════════
lowerDeclarations : LowerCtx -> List Declaration -> List GoDecl
lowerDeclarations ctx decls =
    List.filterMap (lowerDecl ctx) decls

lowerDecl : LowerCtx -> Declaration -> Maybe GoDecl
lowerDecl ctx decl =
    case decl of
        FunDecl name params body _ ->
            Just (lowerFunction ctx name params body)
        
        _ ->
            Nothing

lowerFunction : LowerCtx -> String -> List Pattern -> Expression -> GoDecl
lowerFunction ctx name params body =
    let
        isMain =
            name == "main"
        goName =
            if isMain then
                "main"
            else
                sanitizeGoIdent name
        goParams =
            List.map lowerParam params
        returnType =
            if isMain then
                ""
            else
                "any"
        -- Track parameter names so isDynamicCallee knows they're dynamic
        pNames =
            List.filterMap extractPatternName params
        bodyCtx =
            { ctx | paramNames = Set.union ctx.paramNames (Set.fromList pNames) }
        -- Generate tuple/pattern bindings for complex parameters
        paramBindings =
            generateParamBindings bodyCtx params
        goBody =
            if isMain then
                List.append paramBindings [ GoExprStmt (GoRawExpr ("sky_runMainTask(" ++ emitGoExprInline (lowerExpr bodyCtx body) ++ ")")) ]
            else
                List.append paramBindings [ GoReturn (lowerExpr bodyCtx body) ]
    in
        GoDeclFunc
            { name = goName
            , params = goParams
            , returnType = returnType
            , body = goBody
            }

-- Generate variable bindings for complex function parameters (tuples, records, etc.)
generateParamBindings : LowerCtx -> List Pattern -> List GoStmt
generateParamBindings ctx params =
    List.concatMap (generateOneParamBinding ctx) params


generateOneParamBinding : LowerCtx -> Pattern -> List GoStmt
generateOneParamBinding ctx pat =
    case pat of
        PVariable _ _ ->
            []

        PWildcard _ ->
            []

        PTuple items _ ->
            let
                paramName =
                    "_p"
                bindings =
                    bindTupleArgs ctx paramName items 0
            in
                if String.isEmpty bindings then
                    []
                else
                    [ GoExprStmt (GoRawExpr bindings) ]

        _ ->
            []


lowerParam : Pattern -> GoParam
lowerParam pat =
    case pat of
        PVariable name _ ->
            { name = sanitizeGoIdent name , type_ = "any" }
        
        PWildcard _ ->
            { name = "_" , type_ = "any" }
        
        _ ->
            { name = "_p" , type_ = "any" }

lowerExpr : LowerCtx -> Expression -> GoExpr
lowerExpr ctx expr =
    case expr of

        -- Literals
        IntLitExpr _ raw _ ->
            GoBasicLit raw
        
        FloatLitExpr _ raw _ ->
            GoBasicLit raw
        
        StringLitExpr s _ ->
            GoStringLit s
        
        CharLitExpr s _ ->

            -- Char literals in Sky are like 'c', emit as Go rune
            GoCallExpr (GoIdent "string")
                [ GoBasicLit
                    ("'" ++ String.slice 1 (String.length s - 1) s ++ "'")
                ]
        
        BoolLitExpr b _ ->
            if b then
                GoIdent "true"
            else
                GoIdent "false"
        
        UnitExpr _ ->
            GoRawExpr "struct{}{}"
        
        -- Variables
        IdentifierExpr name _ ->
            lowerIdentifier ctx name
        
        QualifiedExpr parts _ ->
            lowerQualified ctx parts
        
        -- Tuple: use sky_wrappers Tuple struct or []any
        TupleExpr items _ ->
            let
                goItems =
                    List.map (lowerExpr ctx) items
                n =
                    List.length items
            in
                if n == 2 then
                    GoRawExpr
                        ("SkyTuple2{V0: "
                            ++ emitGoExprInline (listGet 0 goItems)
                            ++ ", V1: "
                            ++ emitGoExprInline (listGet 1 goItems)
                            ++ "}"
                        )
                else
                    if n == 3 then
                        GoRawExpr
                            ("SkyTuple3{V0: "
                                ++ emitGoExprInline (listGet 0 goItems)
                                ++ ", V1: "
                                ++ emitGoExprInline (listGet 1 goItems)
                                ++ ", V2: "
                                ++ emitGoExprInline (listGet 2 goItems)
                                ++ "}"
                            )
                    else
                        GoSliceLit goItems
        
        -- List
        ListExpr items _ ->
            GoSliceLit (List.map (lowerExpr ctx) items)
        
        -- Record: map[string]any
        RecordExpr fields _ ->
            GoMapLit
                (
                List.map (\f -> ( GoStringLit f.name , lowerExpr ctx f.value ))
                    fields
                )
        
        -- Record update
        RecordUpdateExpr base fields _ ->
            lowerRecordUpdate ctx base fields
        
        -- Field access
        FieldAccessExpr target fieldName _ ->

            -- records are map[string]any, so use index
            GoIndexExpr
                (GoCallExpr (GoIdent "sky_asMap") [ lowerExpr ctx target ])
                (GoStringLit fieldName)
        
        -- Function call
        CallExpr callee args _ ->
            lowerCall ctx callee args
        
        -- Lambda
        LambdaExpr params body _ ->
            lowerLambda ctx params body
        
        -- If/then/else
        IfExpr condition thenBranch elseBranch _ ->
            lowerIf ctx condition thenBranch elseBranch
        
        -- Let/in
        LetExpr bindings body _ ->
            lowerLet ctx bindings body
        
        -- Case/of
        CaseExpr subject branches _ ->
            lowerCase ctx subject branches
        
        -- Binary operators
        BinaryExpr op left right _ ->
            lowerBinary ctx op left right
        
        -- Negation
        NegateExpr inner _ ->
            GoUnaryExpr "-" (lowerExpr ctx inner)
        
        -- Parenthesized
        ParenExpr inner _ ->
            lowerExpr ctx inner

-- ══════════════════════════════════════════════════════
-- IDENTIFIER LOWERING
-- ══════════════════════════════════════════════════════
lowerIdentifier : LowerCtx -> String -> GoExpr
lowerIdentifier ctx name =

    -- Check if it's a constructor
    case Dict.get name ctx.importedConstructors of
        Just info ->
            if info.arity == 0 then

                -- Zero-arg constructor: emit as value
                lowerConstructorValue name info
            else

                -- Multi-arg constructor: reference the constructor function
                GoIdent (sanitizeGoIdent name)
        
        Nothing ->

            -- Check if it's a well-known constructor
            if name == "Ok" then
                GoIdent "SkyOk"
            else
                if name == "Err" then
                    GoIdent "SkyErr"
                else
                    if name == "Just" then
                        GoIdent "SkyJust"
                    else
                        if name == "Nothing" then
                            GoCallExpr (GoIdent "SkyNothing") []
                        else
                            if name == "True" then
                                GoIdent "true"
                            else
                                if name == "False" then
                                    GoIdent "false"
                                else if name == "not" then
                                    GoIdent "sky_not"
                                else if name == "fst" then
                                    GoIdent "sky_fst"
                                else if name == "snd" then
                                    GoIdent "sky_snd"
                                else if name == "errorToString" then
                                    GoIdent "sky_errorToString"
                                else if name == "println" then
                                    GoIdent "sky_println"
                                else if name == "identity" then
                                    GoIdent "sky_identity"
                                else if name == "always" then
                                    GoIdent "sky_always"
                                else if name == "js" then
                                    GoIdent "sky_js"
                                else if name == "modBy" then
                                    GoIdent "sky_modBy"
                                else if name == "clamp" then
                                    GoIdent "sky_clamp"
                                else
                                    -- Dynamic stdlib lookup: check exposedStdlib dict
                                    case Dict.get name ctx.exposedStdlib of
                                        Just modPath ->
                                            lowerStdlibExposed modPath name

                                        Nothing ->
                                            if not (String.isEmpty ctx.modulePrefix) && listContains name ctx.localFunctions then
                                    let
                                        goName =
                                            ctx.modulePrefix ++ "_" ++ capitalizeFirst (sanitizeGoIdent name)
                                    in
                                        if isZeroArityFn name ctx then
                                            GoCallExpr (GoIdent goName) []
                                        else
                                            GoIdent goName
                                else if isZeroArityFn name ctx then
                                    GoCallExpr (GoIdent (sanitizeGoIdent name)) []
                                else
                                    GoIdent (sanitizeGoIdent name)

-- Convention-based lowering for stdlib exposed names.
-- Uses module path to determine Go calling convention.
-- Adding new functions to stdlib only requires updating getStdlibExports.
lowerStdlibExposed : String -> String -> GoExpr
lowerStdlibExposed modPath name =
    if modPath == "Std.Html" then
        -- Html module: element constructors, void elements, and special nodes
        if name == "text" then
            GoIdent "sky_htmlText"
        else if name == "raw" then
            GoIdent "sky_htmlRaw"
        else if name == "styleNode" then
            GoIdent "sky_htmlStyleNode"
        else if name == "input" || name == "br" || name == "hr" || name == "img" || name == "meta" then
            GoCallExpr (GoIdent "sky_htmlVoid") [ GoStringLit name ]
        else if name == "render" || name == "toString" then
            GoIdent "sky_htmlRender"
        else if name == "escapeHtml" then
            GoIdent "sky_htmlEscapeHtml"
        else if name == "escapeAttr" then
            GoIdent "sky_htmlEscapeAttr"
        else if name == "attrToString" then
            GoIdent "sky_htmlAttrToString"
        else if name == "node" then
            GoIdent "sky_htmlEl"
        else if name == "voidNode" then
            GoIdent "sky_htmlVoid"
        else
            -- Convention: all other Std.Html names are element constructors
            -- Handle renamed elements (Sky uses mainNode/headerNode/etc to avoid keyword collisions)
            let
                tagName =
                    if name == "mainNode" then "main"
                    else if name == "headerNode" then "header"
                    else if name == "footerNode" then "footer"
                    else if name == "codeNode" then "code"
                    else if name == "linkNode" then "link"
                    else if name == "titleNode" then "title"
                    else if name == "htmlNode" then "html"
                    else if name == "headNode" then "head"
                    else name
            in
                GoCallExpr (GoIdent "sky_htmlEl") [ GoStringLit tagName ]
    else if modPath == "Std.Html.Attributes" then
        -- Attributes: convention → sky_attr(name, value)
        if name == "attribute" then
            GoIdent "sky_attrCustom"
        else if name == "boolAttribute" then
            GoIdent "sky_attrBool"
        else if name == "dataAttribute" then
            GoIdent "sky_attrData"
        else if name == "type_" then
            GoCallExpr (GoIdent "sky_attrSimple") [ GoStringLit "type" ]
        else
            -- Convention: all other attrs are simple key-value pairs
            GoCallExpr (GoIdent "sky_attrSimple") [ GoStringLit name ]
    else if modPath == "Std.Live.Events" then
        -- Events: convention → sky_evt(eventType, msg)
        if String.startsWith "on" name then
            let
                evtName =
                    String.toLower (String.slice 2 (String.length name) name)
            in
                GoCallExpr (GoIdent "sky_evtHandler") [ GoStringLit evtName ]
        else
            -- fileMaxSize etc. — numeric config helpers
            GoIdent ("sky_evt_" ++ name)
    else if modPath == "Std.Css" then
        -- CSS: units and special functions have dedicated helpers
        if name == "stylesheet" then GoIdent "sky_cssStylesheet"
        else if name == "rule" then GoIdent "sky_cssRule"
        else if name == "property" then GoIdent "sky_cssProp"
        else if name == "styles" then GoIdent "sky_cssStyles"
        else if name == "px" then GoIdent "sky_cssPx"
        else if name == "rem" then GoIdent "sky_cssRem"
        else if name == "em" then GoIdent "sky_cssEm"
        else if name == "pct" then GoIdent "sky_cssPct"
        else if name == "hex" then GoIdent "sky_cssHex"
        else if name == "rgb" then GoIdent "sky_cssRgb"
        else if name == "rgba" then GoIdent "sky_cssRgba"
        else if name == "margin2" then GoIdent "sky_cssMargin2"
        else if name == "padding2" then GoIdent "sky_cssPadding2"
        else if name == "media" then GoIdent "sky_cssMedia"
        else if name == "keyframes" then GoIdent "sky_cssKeyframes"
        else if name == "frame" then GoIdent "sky_cssFrame"
        else
            -- Convention: all other CSS names are property shorthand functions
            -- margin → property "margin", fontSize → property "font-size", etc.
            GoCallExpr (GoIdent "sky_cssPropFn") [ GoStringLit (cssNameToProperty name) ]
    else if modPath == "Std.Live" then
        if name == "app" then GoIdent "sky_liveApp"
        else if name == "route" then GoIdent "sky_liveRoute"
        else GoIdent ("sky_live_" ++ name)
    else if modPath == "Std.Cmd" then
        if name == "none" then GoCallExpr (GoIdent "sky_cmdNone") []
        else if name == "batch" then GoIdent "sky_cmdBatch"
        else GoIdent ("sky_cmd_" ++ name)
    else if modPath == "Std.Sub" then
        if name == "none" then GoCallExpr (GoIdent "sky_subNone") []
        else if name == "batch" then GoIdent "sky_subBatch"
        else GoIdent ("sky_sub_" ++ name)
    else if modPath == "Std.Time" then
        if name == "every" then GoIdent "sky_timeEvery"
        else GoIdent ("sky_time_" ++ name)
    else
        GoIdent (sanitizeGoIdent name)


-- Convert camelCase CSS name to kebab-case property name
-- fontSize → font-size, backgroundColor → background-color
cssNameToProperty : String -> String
cssNameToProperty name =
    cssNameToPropertyLoop name 0 ""


cssNameToPropertyLoop : String -> Int -> String -> String
cssNameToPropertyLoop name idx acc =
    if idx >= String.length name then
        acc
    else
        let
            ch =
                String.slice idx (idx + 1) name
            isUpper =
                ch == "A" || ch == "B" || ch == "C" || ch == "D" || ch == "E" ||
                ch == "F" || ch == "G" || ch == "H" || ch == "I" || ch == "J" ||
                ch == "K" || ch == "L" || ch == "M" || ch == "N" || ch == "O" ||
                ch == "P" || ch == "Q" || ch == "R" || ch == "S" || ch == "T" ||
                ch == "U" || ch == "V" || ch == "W" || ch == "X" || ch == "Y" || ch == "Z"
        in
            if isUpper && idx > 0 then
                cssNameToPropertyLoop name (idx + 1) (acc ++ "-" ++ String.toLower ch)
            else
                cssNameToPropertyLoop name (idx + 1) (acc ++ ch)


lowerConstructorValue : String -> CtorInfo -> GoExpr
lowerConstructorValue name info =

    -- Zero-arg constructor: map[string]any{"Tag": idx, "SkyName": "Name"}
    GoMapLit
        [ ( GoStringLit "Tag" , GoBasicLit (String.fromInt info.tagIndex) )
        , ( GoStringLit "SkyName" , GoStringLit name )
        ]

lowerQualified : LowerCtx -> List String -> GoExpr
lowerQualified ctx parts =
    let
        qualName =
            String.join "." parts
    in
        -- Map well-known stdlib functions to Go runtime calls
        if qualName == "String.fromInt" then
            GoIdent "sky_stringFromInt"
        else if qualName == "String.fromFloat" then
            GoIdent "sky_stringFromFloat"
        else if qualName == "String.toUpper" then
            GoIdent "sky_stringToUpper"
        else if qualName == "String.toLower" then
            GoIdent "sky_stringToLower"
        else if qualName == "String.length" then
            GoIdent "sky_stringLength"
        else if qualName == "String.join" then
            GoIdent "sky_stringJoin"
        else if qualName == "String.contains" then
            GoIdent "sky_stringContains"
        else if qualName == "String.trim" then
            GoIdent "sky_stringTrim"
        else if qualName == "String.isEmpty" then
            GoIdent "sky_stringIsEmpty"
        else if qualName == "String.startsWith" then
            GoIdent "sky_stringStartsWith"
        else if qualName == "String.endsWith" then
            GoIdent "sky_stringEndsWith"
        else if qualName == "String.split" then
            GoIdent "sky_stringSplit"
        else if qualName == "String.replace" then
            GoIdent "sky_stringReplace"
        else if qualName == "String.toInt" then
            GoIdent "sky_stringToInt"
        else if qualName == "String.toFloat" then
            GoIdent "sky_stringToFloat"
        else if qualName == "String.append" then
            GoIdent "sky_stringAppend"
        else if qualName == "String.slice" then
            GoIdent "sky_stringSlice"
        else if qualName == "List.map" then
            GoIdent "sky_listMap"
        else if qualName == "List.filter" then
            GoIdent "sky_listFilter"
        else if qualName == "List.foldl" then
            GoIdent "sky_listFoldl"
        else if qualName == "List.foldr" then
            GoIdent "sky_listFoldr"
        else if qualName == "List.length" then
            GoIdent "sky_listLength"
        else if qualName == "List.head" then
            GoIdent "sky_listHead"
        else if qualName == "List.reverse" then
            GoIdent "sky_listReverse"
        else if qualName == "List.isEmpty" then
            GoIdent "sky_listIsEmpty"
        else if qualName == "List.append" then
            GoIdent "sky_listAppend"
        else if qualName == "List.concatMap" then
            GoIdent "sky_listConcatMap"
        else if qualName == "List.filterMap" then
            GoIdent "sky_listFilterMap"
        else if qualName == "List.indexedMap" then
            GoIdent "sky_listIndexedMap"
        else if qualName == "List.concat" then
            GoIdent "sky_listConcat"
        else if qualName == "List.drop" then
            GoIdent "sky_listDrop"
        else if qualName == "List.member" then
            GoIdent "sky_listMember"
        else if qualName == "Log.println" then
            GoIdent "sky_println"
        else if qualName == "Args.skyVersion" then
            GoIdent "skyVersion"
        else if qualName == "File.readFile" then
            GoIdent "sky_fileRead"
        else if qualName == "File.writeFile" then
            GoIdent "sky_fileWrite"
        else if qualName == "File.mkdirAll" then
            GoIdent "sky_fileMkdirAll"
        else if qualName == "Process.exit" then
            GoIdent "sky_processExit"
        else if qualName == "Process.run" then
            GoIdent "sky_processRun"
        else if qualName == "Args.getArgs" then
            GoIdent "sky_processGetArgs"
        else if qualName == "Args.getArg" then
            GoIdent "sky_processGetArg"
        else if qualName == "Ref.new" then
            GoIdent "sky_refNew"
        else if qualName == "Ref.get" then
            GoIdent "sky_refGet"
        else if qualName == "Ref.set" then
            GoIdent "sky_refSet"
        else if qualName == "Dict.empty" then
            GoCallExpr (GoIdent "sky_dictEmpty") []
        else if qualName == "Dict.insert" then
            GoIdent "sky_dictInsert"
        else if qualName == "Dict.get" then
            GoIdent "sky_dictGet"
        else if qualName == "Dict.keys" then
            GoIdent "sky_dictKeys"
        else if qualName == "Dict.values" then
            GoIdent "sky_dictValues"
        else if qualName == "Dict.toList" then
            GoIdent "sky_dictToList"
        else if qualName == "Dict.fromList" then
            GoIdent "sky_dictFromList"
        else if qualName == "Dict.map" then
            GoIdent "sky_dictMap"
        else if qualName == "Dict.foldl" then
            GoIdent "sky_dictFoldl"
        else if qualName == "Dict.union" then
            GoIdent "sky_dictUnion"
        else if qualName == "Dict.remove" then
            GoIdent "sky_dictRemove"
        else if qualName == "Dict.member" then
            GoIdent "sky_dictMember"
        else if qualName == "Set.empty" then
            GoCallExpr (GoIdent "sky_setEmpty") []
        else if qualName == "Set.singleton" then
            GoIdent "sky_setSingleton"
        else if qualName == "Set.insert" then
            GoIdent "sky_setInsert"
        else if qualName == "Set.member" then
            GoIdent "sky_setMember"
        else if qualName == "Set.union" then
            GoIdent "sky_setUnion"
        else if qualName == "Set.diff" then
            GoIdent "sky_setDiff"
        else if qualName == "Set.toList" then
            GoIdent "sky_setToList"
        else if qualName == "Set.fromList" then
            GoIdent "sky_setFromList"
        else if qualName == "Set.isEmpty" then
            GoIdent "sky_setIsEmpty"
        else if qualName == "Set.remove" then
            GoIdent "sky_setRemove"
        else if qualName == "Char.isUpper" then
            GoIdent "sky_charIsUpper"
        else if qualName == "Char.isLower" then
            GoIdent "sky_charIsLower"
        else if qualName == "Char.isDigit" then
            GoIdent "sky_charIsDigit"
        else if qualName == "Char.isAlpha" then
            GoIdent "sky_charIsAlpha"
        else if qualName == "Char.isAlphaNum" then
            GoIdent "sky_charIsAlphaNum"
        else if qualName == "Char.toUpper" then
            GoIdent "sky_charToUpper"
        else if qualName == "Char.toLower" then
            GoIdent "sky_charToLower"
        else if qualName == "String.fromChar" then
            GoIdent "sky_stringFromChar"
        else if qualName == "String.toList" then
            GoIdent "sky_stringToList"
        else if qualName == "String.toBytes" then
            GoIdent "sky_stringToBytes"
        else if qualName == "String.fromBytes" then
            GoIdent "sky_stringFromBytes"
        else if qualName == "Io.readLine" then
            GoIdent "sky_readLine"
        else if qualName == "Io.readAllStdin" then
            GoIdent "sky_readAllStdin"
        else if qualName == "Io.readBytes" then
            GoIdent "sky_readBytes"
