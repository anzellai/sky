module Main exposing (main)

import Sky.Core.Prelude exposing (..)
import Sky.Core.String as String
import Sky.Core.List as List
import Sky.Core.Args as Args
import Sky.Core.Process as Process
import Sky.Core.File as File
import Sky.Core.Io as Io
import Std.Log exposing (println)
import Compiler.Ast as Ast
import Compiler.Pipeline as Pipeline
import Compiler.Lexer as Lexer
import Compiler.Parser as Parser
import Compiler.Checker as Checker
import Compiler.Resolver as Resolver
import Formatter.Format as Format
import Lsp.Server as LspServer
import Ffi.BindingGen as BindingGen

main =
    let
        command =
            case Args.getArg 1 of

                Just cmd ->
                    cmd

                Nothing ->
                    "help"
    in
        runCommand command


runCommand command =
    if command == "build" then
        cmdBuild ()
    else if command == "run" then
        cmdRun ()
    else if command == "check" then
        cmdCheck ()
    else if command == "fmt" then
        cmdFmt ()
    else if command == "clean" then
        cmdClean ()
    else if command == "lsp" then
        LspServer.startServer ()
    else if command == "init" then
        cmdInit ()
    else if command == "add" then
        cmdAdd ()
    else if command == "install" then
        cmdInstall ()
    else if command == "remove" then
        cmdRemove ()
    else if command == "update" then
        cmdUpdate ()
    else if command == "upgrade" then
        cmdUpgrade ()
    else if command == "version" || command == "--version" || command == "-v" then
        let
            _ = println ("sky " ++ Args.skyVersion)
        in
            ()
    else
        cmdHelp ()


cmdBuild _ =
    let
        entryFile =
            case Args.getArg 2 of

                Just f ->
                    f

                Nothing ->
                    "src/Main.sky"
        outDir = "sky-out"
    in
        case Pipeline.compile entryFile outDir of

            Err e ->
                let
                    _ = println ("Error: " ++ e)
                in
                    Process.exit 1

            Ok code ->
                buildGoProject outDir


buildGoProject outDir =
    let
        goModPath = outDir ++ "/go.mod"
        goSumPath = outDir ++ "/go.sum"
        goModExists =
            case File.readFile goModPath of

                Ok _ ->
                    True

                Err _ ->
                    False
        _ =
            if goModExists then
                ()
            else
                let
                    _ = File.writeFile goModPath
                            "module sky-app\n\ngo 1.26.0\n"
                in
                    ()
        hasFfiWrappers =
            case Process.run "sh"
                     [ "-c"
                     , "ls " ++ outDir ++ "/sky_*.go " ++ outDir ++ "/skylive_rt/*.go 2>/dev/null | head -1"
                     ] of

                Ok output ->
                    not (String.isEmpty (String.trim output))

                Err _ ->
                    False
        goSumExists =
            case File.readFile goSumPath of

                Ok _ ->
                    True

                Err _ ->
                    False
        _ =
            if hasFfiWrappers && not goSumExists then
                let
                    _ = println "Running go mod tidy..."
                in
                    Process.run "sh"
                        [ "-c"
                        , "cd " ++ outDir ++ " && go mod tidy 2>&1"
                        ]
            else
                Ok ""
        _ = println "Running go build..."
        buildResult =
            Process.run "sh"
                [ "-c"
                , "cd " ++ outDir ++ " && go build -gcflags=all=-l -ldflags='-X main.skyVersion=" ++ Args.skyVersion ++ "' -o app"
                ]
    in
        handleBuildResult outDir buildResult


handleBuildResult outDir buildResult =
    case buildResult of
        Ok _ ->
            let
                _ = println ("Build complete: " ++ outDir ++ "/app")
                _ = checkForUpdates ()
            in
                ()

        Err e ->
            if String.contains "no required module" (errorToString e) then
                retryBuildWithTidy outDir e
            else
                let
                    _ = println ("go build failed: " ++ errorToString e)
                in
                    Process.exit 1


retryBuildWithTidy outDir originalErr =
    let
        _ = println "Missing Go dependencies, running go mod tidy..."
        tidyResult =
            Process.run "sh"
                [ "-c" , "cd " ++ outDir ++ " && go mod tidy 2>&1" ]
        _ =
            case tidyResult of
                Ok _ ->
                    ()

                Err te ->
                    let
                        _ = println ("go mod tidy failed: " ++ errorToString te)
                    in
                        ()
        _ = println "Retrying go build..."
        retryResult =
            Process.run "sh"
                [ "-c"
                , "cd " ++ outDir ++ " && go build -gcflags=all=-l -o app"
                ]
    in
        case retryResult of
            Ok _ ->
                let
                    _ = println ("Build complete: " ++ outDir ++ "/app")
                in
                    ()

            Err retryErr ->
                let
                    _ = println ("go build failed: " ++ errorToString retryErr)
                in
                    Process.exit 1


cmdRun _ =
    let
        _ = cmdBuild ()
        runResult = Process.run "sh" [ "-c" , "./sky-out/app" ]
    in
        case runResult of

            Ok output ->
                let
                    _ = println output
                in
                    ()

            Err e ->
                let
                    _ = println (errorToString e)
                in
                    Process.exit 1


cmdCheck _ =
    let
        entryFile =
            case Args.getArg 2 of

                Just f ->
                    f

                Nothing ->
                    "src/Main.sky"
    in
        case File.readFile entryFile of

            Err readErr ->
                let
                    _ = println ("Cannot read: " ++ entryFile)
                in
                    Process.exit 1

            Ok source ->
                checkSource entryFile source


checkSource entryFile source =
    let
        lexResult = Lexer.lex source
    in
        case Parser.parse lexResult.tokens of

            Err e ->
                let
                    _ = println ("Parse error: " ++ e)
                in
                    Process.exit 1

            Ok mod ->
                let
                    ( combinedEnv , registry , aliases ) =
                        Pipeline.buildCheckEnv entryFile mod
                    checkResult =
                        Checker.checkModuleWithRegistryAndAliases mod (Just combinedEnv) (Just registry) (Just aliases)
                in
                    handleCheckResult entryFile checkResult


handleCheckResult entryFile checkResult =
    case checkResult of

            Ok result ->
                if List.isEmpty result.diagnostics then
                    let
                        _ = println
                                (
                                "Type check passed: " ++ entryFile
                                )
                    in
                        ()
                else
                    let
                        _ =
                            List.map
                                (
                                \d ->
                                    println
                                        ("  [!] " ++ d)
                                )
                                result.diagnostics
                        _ = println ""
                    in
                        let
                            _ =
                                println
                                    (
                                    "Type check failed with " ++ String.fromInt
                                                                     (
                                                                     List.length
                                                                         result.diagnostics
                                                                     ) ++ " error(s): " ++ entryFile
                                    )
                        in
                            Process.exit 1

            Err e ->
                let
                    _ = println ("Type error: " ++ e)
                in
                    Process.exit 1


isGoStdlib : String -> Bool
isGoStdlib name =
    name == "archive" || name == "bufio" || name == "bytes" || name == "compress" || name == "container" || name == "context" || name == "crypto" || name == "database" || name == "debug" || name == "embed" || name == "encoding" || name == "errors" || name == "flag" || name == "fmt" || name == "go" || name == "hash" || name == "html" || name == "image" || name == "io" || name == "log" || name == "math" || name == "mime" || name == "net" || name == "os" || name == "path" || name == "reflect" || name == "regexp" || name == "runtime" || name == "sort" || name == "strconv" || name == "strings" || name == "sync" || name == "syscall" || name == "testing" || name == "text" || name == "time" || name == "unicode" || name == "unsafe"


cmdInit _ =
    let
        projectName = resolveProjectName ()
        tomlExists =
            case File.readFile "sky.toml" of

                Ok _ ->
                    True

                Err _ ->
                    False
    in
        if tomlExists then
            println "sky.toml already exists. Project already initialised."
        else
            initProject projectName


resolveProjectName _ =
    case Args.getArg 2 of

        Just name ->
            name

        Nothing ->
            inferProjectName ()


inferProjectName _ =
    case Process.run "pwd" [] of

        Ok cwd ->
            extractDirName (String.trim cwd)

        Err _ ->
            "sky-project"


extractDirName cwd =
    case List.reverse (String.split "/" cwd) of

        last :: _ ->
            last

        [] ->
            "sky-project"


initProject projectName =
    let
        tomlContent =
            String.join "\n"
                [ "name = \"" ++ projectName ++ "\""
                , "version = \"0.1.0\""
                , "entry = \"src/Main.sky\""
                , ""
                , "[source]"
                , "root = \"src\""
                , ""
                ]
        mainContent =
            String.join "\n"
                [ "module Main exposing (main)"
                , ""
                , "import Sky.Core.Prelude exposing (..)"
                , "import Std.Log exposing (println)"
                , ""
                , "main = println \"Hello from Sky!\""
                , ""
                ]
        gitignoreContent =
            String.join "\n"
                [ "# Build artifacts"
                , "sky-out/"
                , "dist/"
                , ""
                , "# Sky cache and dependencies"
                , ".skycache/"
                , ".skydeps/"
                , ""
                , "# Environment"
                , ".env"
                , ".env.*"
                , ""
                , "# OS"
                , ".DS_Store"
                , ""
                ]
        _ = File.writeFile "sky.toml" tomlContent
        _ = File.mkdirAll "src"
        mainPath = "src/Main.sky"
        mainExists =
            case File.readFile mainPath of

                Ok _ ->
                    True

                Err _ ->
                    False
        _ =
            if mainExists then
                ()
            else
                let
                    _ = File.writeFile mainPath mainContent
                in
                    ()
        gitignorePath = ".gitignore"
        gitignoreExists =
            case File.readFile gitignorePath of

                Ok _ ->
                    True

                Err _ ->
                    False
        _ =
            if gitignoreExists then
                ()
            else
                let
                    _ = File.writeFile gitignorePath gitignoreContent
                in
                    ()
        claudeMdCreated = copyClaudeMdTemplate ()
        _ = println ("Initialised Sky project: " ++ projectName)
        _ = println ""
        _ = println "Created:"
        _ = println "  sky.toml        Project configuration"
        _ =
            if mainExists then
                ()
            else
                let
                    _ = println "  src/Main.sky    Entry point"
                in
                    ()
        _ =
            if gitignoreExists then
                ()
            else
                let
                    _ = println "  .gitignore      Git ignore rules"
                in
                    ()
        _ =
            if claudeMdCreated then
                let
                    _ = println "  CLAUDE.md       AI assistant context"
                in
                    ()
            else
                ()
        _ = println ""
        _ = println "Get started:"
        _ = println "  sky build       Compile to binary"
        _ = println "  sky run         Build and run"
    in
        ()


copyClaudeMdTemplate _ =
    case File.readFile "CLAUDE.md" of

        Ok _ ->
            False

        Err _ ->
            tryCopyTemplate ()


tryCopyTemplate _ =
    let
        skyBin = findSkyBin ()
        binDir = dirOfPath skyBin
        templatePath = binDir ++ "/../templates/CLAUDE.md"
    in
        case File.readFile templatePath of

            Ok content ->
                let
                    _ = File.writeFile "CLAUDE.md" content
                in
                    True

            Err _ ->
                tryAlternateTemplatePath binDir


tryAlternateTemplatePath binDir =
    let
        altPath = binDir ++ "/templates/CLAUDE.md"
    in
        case File.readFile altPath of

            Ok content ->
                let
                    _ = File.writeFile "CLAUDE.md" content
                in
                    True

            Err _ ->
                False


cmdAdd _ =
    case Args.getArg 2 of

        Nothing ->
            println "Usage: sky add <package>"

        Just pkg ->
            let
                _ = println ("Adding " ++ pkg ++ "...")
                firstPart =
                    case String.split "/" pkg of

                        first :: _ ->
                            first

                        [  ] ->
                            pkg
            in
                if isGoStdlib firstPart || isGoStdlib pkg then
                    addGoStdlib pkg
                else if String.contains "." firstPart then
                    detectAndInstall pkg
                else
                    println
                        (
                        "Unknown package: " ++ pkg ++ ". Use github.com/owner/repo format."
                        )


addGoStdlib pkg =
    let
        cacheDir = ".skycache/go/" ++ safePkgName pkg
        _ = File.mkdirAll cacheDir
        _ = ensureGoModDir ()
        _ = generateGoBindings pkg cacheDir
        _ = addGoDepToToml pkg "latest"
        _ = println "Done."
        _ = checkForUpdates ()
    in
        ()


detectAndInstall pkg =
    let
        tmpDir = ".skycache/detect_" ++ String.replace "/" "_" pkg
        _ = File.mkdirAll ".skycache"
        cloneResult =
            Process.run "git"
                [ "clone" , "--depth" , "1" , "https://" ++ pkg , tmpDir ]
    in
        case cloneResult of

            Ok _ ->
                detectClonedPackageType pkg tmpDir

            Err _ ->
                installAsGoPackage pkg ""


detectClonedPackageType pkg tmpDir =
    let
        hasSkyToml =
            case File.readFile (tmpDir ++ "/sky.toml") of

                Ok _ ->
                    True

                Err _ ->
                    False
    in
        if hasSkyToml then
            installAsSkyPackage pkg tmpDir
        else
            installAsGoPackage pkg tmpDir


installAsSkyPackage pkg tmpDir =
    let
        targetDir = ".skydeps/" ++ pkg
        _ = File.mkdirAll ".skydeps"
        _ = Process.run "rm" [ "-rf" , targetDir ]
        _ = Process.run "mv" [ tmpDir , targetDir ]
        _ = addSkyDepToToml pkg "1.0.0"
        _ = println ("Added Sky package: " ++ pkg)
        _ = println "Done."
        _ = checkForUpdates ()
    in
        ()


installAsGoPackage pkg tmpDir =
    let
        _ =
            if String.isEmpty tmpDir then
                ()
            else
                let
                    _ = Process.run "rm" [ "-rf" , tmpDir ]
                in
                    ()
        _ = ensureGoModDir ()
        getResult =
            Process.run "sh"
                [ "-c" , "cd .skycache/gomod && go get " ++ pkg ++ "@latest" ]
    in
        handleGoPackageResult pkg getResult


handleGoPackageResult pkg getResult =
    case getResult of

        Ok _ ->
            let
                _ = println ("Added Go package: " ++ pkg)
                cacheDir = ".skycache/go/" ++ safePkgName pkg
                _ = File.mkdirAll cacheDir
                _ = generateGoBindings pkg cacheDir
                _ = addGoDepToToml pkg "latest"
                _ = println "Done."
                _ = checkForUpdates ()
            in
                ()

        Err e ->
            let
                _ =
                    println
                        ("Failed to add " ++ pkg ++ ": " ++ errorToString e)
                _ = Process.exit 1
            in
                ()


generateGoBindings pkg cacheDir =
    case BindingGen.generateBindings pkg cacheDir of

        Ok content ->
            let
                _ = println ("Generated bindings for " ++ pkg ++ " at " ++ cacheDir)
            in
                ()

        Err e ->
            let
                _ = println ("Warning: binding generation failed: " ++ e)
            in
                ()


ensureGoModDir _ =
    let
        _ = File.mkdirAll ".skycache/gomod"
        goModPath = ".skycache/gomod/go.mod"
    in
        case File.readFile goModPath of

            Ok _ ->
                ()

            Err _ ->
                let
                    _ = File.writeFile goModPath "module skycache\n\ngo 1.26.0\n"
                in
                    ()


cmdInstall _ =
    let
        _ = println "Installing dependencies..."
        _ = ensureGoModDir ()
        _ = installFromSkyToml ()
        _ = installFromSkyToml ()
        _ = autoGenerateBindings ()
        _ = preFilterBindings ()
        tidyResult =
            Process.run "sh" [ "-c" , "cd .skycache/gomod && go mod tidy" ]
        _ =
            case tidyResult of

                Ok _ ->
                    ()

                Err e ->
                    let
                        _ = println ("Install warning: " ++ errorToString e)
                    in
                        ()
        _ = checkForUpdates ()
    in
        println "Install complete."


installFromSkyToml _ =
    case File.readFile "sky.toml" of

        Err _ ->
            ()

        Ok content ->
            let
                lines = String.split "\n" content
            in
                installTomlDeps lines False


installTomlDeps lines inGoDeps =
    case lines of

        [  ] ->
            ()

        line :: rest ->
            let
                trimmed = String.trim line
                isGoDepsHeader =
                    trimmed == "[\"go.dependencies\"]" || trimmed == "[go.dependencies]"
            in
                if isGoDepsHeader then
                    installTomlDeps rest True
                else if String.startsWith "[" trimmed && not isGoDepsHeader then
                    installTomlDeps rest False
                else if inGoDeps && String.contains "=" trimmed then
                    let
                        pkg =
                            String.trim
                                (
                                String.replace "\"" ""
                                    (
                                    String.trim
                                        (
                                        case String.split "=" trimmed of

                                            key :: _ ->
                                                key

                                            [  ] ->
                                                ""
                                        )
                                    )
                                )
                        safeName =
                            String.replace "-" "_"
                                (
                                String.replace "/" "_"
                                    (String.replace "." "_" pkg)
                                )
                        bindingPath =
                            ".skycache/go/" ++ safeName ++ "/bindings.skyi"
                    in
                        case File.readFile bindingPath of

                            Ok _ ->
                                installTomlDeps rest True

                            Err _ ->
                                let
                                    firstPart =
                                        case String.split "/" pkg of

                                            first :: _ ->
                                                first

                                            [  ] ->
                                                pkg
                                    _ =
                                        println
                                            (
                                            "   Generating bindings for " ++ pkg ++ "..."
                                            )
                                in
                                    if isGoStdlib firstPart || isGoStdlib pkg then
                                        let
                                            cacheDir =
                                                ".skycache/go/" ++ safeName
                                            _ = File.mkdirAll cacheDir
                                        in
                                            let
                                                _ =
                                                    generateGoBindings pkg
                                                        cacheDir
                                            in
                                                installTomlDeps rest True
                                    else if String.contains "." firstPart then
                                        let
                                            _ = detectAndInstall pkg
                                        in
                                            installTomlDeps rest True
                                    else
                                        installTomlDeps rest True
                else
                    installTomlDeps rest inGoDeps


installFromSkyToml _ =
    case File.readFile "sky.toml" of

        Err _ ->
            ()

        Ok content ->
            let
                lines = String.split "\n" content
            in
                installTomlDeps lines False


installTomlDeps lines inGoDeps =
    case lines of

        [  ] ->
            ()

        line :: rest ->
            let
                trimmed = String.trim line
                isGoDepsHeader =
                    trimmed == "[\"go.dependencies\"]" || trimmed == "[go.dependencies]"
            in
                if isGoDepsHeader then
                    installTomlDeps rest True
                else if String.startsWith "[" trimmed && not isGoDepsHeader then
                    installTomlDeps rest False
                else if inGoDeps && String.contains "=" trimmed then
                    let
                        pkg =
                            String.trim
                                (
                                String.replace "\"" ""
                                    (
                                    String.trim
                                        (
                                        case String.split "=" trimmed of

                                            key :: _ ->
                                                key

                                            [  ] ->
                                                ""
                                        )
                                    )
                                )
                        safeName =
                            String.replace "-" "_"
                                (
                                String.replace "/" "_"
                                    (String.replace "." "_" pkg)
                                )
                        bindingPath =
                            ".skycache/go/" ++ safeName ++ "/bindings.skyi"
                    in
                        case File.readFile bindingPath of

                            Ok _ ->
                                installTomlDeps rest True

                            Err _ ->
                                let
                                    firstPart =
                                        case String.split "/" pkg of

                                            first :: _ ->
                                                first

                                            [  ] ->
                                                pkg
                                    _ =
                                        println
                                            (
                                            "   Generating bindings for " ++ pkg ++ "..."
                                            )
                                in
                                    if isGoStdlib firstPart || isGoStdlib pkg then
                                        let
                                            cacheDir =
                                                ".skycache/go/" ++ safeName
                                            _ = File.mkdirAll cacheDir
                                            _ = generateGoBindings pkg cacheDir
                                        in
                                            installTomlDeps rest True
                                    else if String.contains "." firstPart then
                                        let
                                            _ = detectAndInstall pkg
                                        in
                                            installTomlDeps rest True
                                    else
                                        installTomlDeps rest True
                else
                    installTomlDeps rest inGoDeps


autoGenerateBindings _ =
    let
        findResult =
            Process.run "sh"
                [ "-c" , "find src/ -name '*.sky' 2>/dev/null | head -100" ]
    in
        case findResult of

            Ok output ->
                let
                    files =
                        List.filter (\f -> not (String.isEmpty (String.trim f)))
                            (String.split "\n" output)
                    _ = List.map (\f -> scanFileForFfiImports f) files
                in
                    ()

            Err _ ->
                ()


scanFileForFfiImports filePath =
    case File.readFile filePath of

        Err _ ->
            ()

        Ok source ->
            let
                lines = String.split "\n" source
                importLines =
                    List.filter
                        (
                        \l ->
                            String.startsWith "import " l && not
                                                                 (
                                                                 String.contains
                                                                     "Sky.Core"
                                                                     l
                                                                 ) && not
                                                                          (
                                                                          String.contains
                                                                              "Std."
                                                                              l
                                                                          ) && not
                                                                                   (
                                                                                   String.contains
                                                                                       "Compiler."
                                                                                       l
                                                                                   ) && not
                                                                                            (
                                                                                            String.contains
                                                                                                "Formatter."
                                                                                                l
                                                                                            ) && not
                                                                                                     (
                                                                                                     String.contains
                                                                                                         "Lsp."
                                                                                                         l
                                                                                                     ) && not
                                                                                                              (
                                                                                                              String.contains
                                                                                                                  "Ffi."
                                                                                                                  l
                                                                                                              )
                        )
                        lines
                _ = List.map (\l -> processImportLine l) importLines
            in
                ()


processImportLine line =
    let
        parts = String.split " " (String.trim line)
        modName =
            if List.length parts >= 2 then
                case List.head (List.drop 1 parts) of

                    Just n ->
                        n

                    Nothing ->
                        ""
            else
                ""
    in
        if String.isEmpty modName || Resolver.isStdlib modName then
            ()
        else
            let
                goPath = Resolver.moduleNameToGoPath modName
                safeName =
                    String.replace "-" "_"
                        (String.replace "/" "_" (String.replace "." "_" goPath))
                bindingPath = ".skycache/go/" ++ safeName ++ "/bindings.skyi"
            in
                case File.readFile bindingPath of

                    Ok _ ->
                        ()

                    Err _ ->
                        let
                            _ =
                                println
                                    (
                                    "   Generating bindings for " ++ goPath ++ "..."
                                    )
                            firstPart =
                                case String.split "/" goPath of

                                    first :: _ ->
                                        first

                                    [  ] ->
                                        ""
                        in
                            if isGoStdlib firstPart || isGoStdlib goPath then
                                let
                                    cacheDir = ".skycache/go/" ++ safeName
                                    _ = File.mkdirAll cacheDir
                                    _ = ensureGoModDir ()
                                in
                                    generateGoBindings goPath cacheDir
                            else if String.contains "." firstPart then
                                detectAndInstall goPath
                            else
                                ()


preFilterBindings _ =
    case Process.run "sh"
             [ "-c"
             , "for f in $(find .skycache/go -name 'bindings.skyi' 2>/dev/null); do " ++ "sz=$(wc -c < \"$f\" 2>/dev/null | tr -d ' '); " ++ "if [ \"$sz\" -gt 10000 ] 2>/dev/null; then " ++ "alias=$(head -1 \"$f\" | awk '{print $2}' | awk -F. '{print $NF}'); " ++ "out=\"${f%.skyi}.filtered.skyi\"; " ++ "skyi-filter \"$f\" \"$alias\" src > \"$out\" 2>/dev/null && " ++ "echo \"   Pre-filtered $f\"; " ++ "fi; done"
             ] of

        Ok output ->
            if not (String.isEmpty (String.trim output)) then
                let
                    _ = println (String.trim output)
                in
                    ()
            else
                ()

        Err _ ->
            ()


cmdUpdate _ =
    case File.readFile "sky.toml" of

        Err _ ->
            println "No sky.toml found. Nothing to update."

        Ok content ->
            let
                _ = println "Updating dependencies..."
                lines = String.split "\n" content
                _ = ensureGoModDir ()
                _ = updateDepsLoop lines "" False
            in
                println "Update complete."


updateDepsLoop lines section inDeps =
    if List.isEmpty lines then
        ()
    else
        let
            line =
                case List.head lines of

                    Just l ->
                        l

                    Nothing ->
                        ""
            rest = List.drop 1 lines
            trimmed = String.trim line
        in
            if isTomlSectionHeader trimmed then
                updateDepsLoop rest trimmed (isSkyOrGoDepSection trimmed)
            else if inDeps && String.contains "=" trimmed then
                let
                    _ = updateOneDep trimmed section
                in
                    updateDepsLoop rest section True
            else
                updateDepsLoop rest section inDeps


isSkyOrGoDepSection header =
    header == "[dependencies]" || header == "[go.dependencies]" || header == "[\"go.dependencies\"]"


updateOneDep depLine section =
    let
        pkgName = extractTomlKey depLine
    in
        if String.isEmpty pkgName then
            ()
        else if section == "[go.dependencies]" || section == "[\"go.dependencies\"]" then
            updateGoDep pkgName
        else
            updateSkyDep pkgName


updateGoDep pkgName =
    let
        _ = println ("   Updating " ++ pkgName ++ "...")
        _ =
            Process.run "sh"
                [ "-c"
                , "cd .skycache/gomod && go get " ++ pkgName ++ "@latest 2>/dev/null"
                ]
    in
        ()


updateSkyDep pkgName =
    let
        _ = println ("   Updating " ++ pkgName ++ "...")
        depDir = ".skydeps/" ++ pkgName
        _ = Process.run "rm" [ "-rf" , depDir ]
        _ =
            Process.run "git"
                [ "clone" , "--depth" , "1" , "https://" ++ pkgName , depDir ]
    in
        ()


cmdUpgrade _ =
    let
        _ = println "Checking for updates..."
        latest = fetchLatestVersionFresh ()
    in
        if String.isEmpty latest then
            println "Could not determine latest version."
        else
            doUpgrade latest


doUpgrade latest =
    let
        current = Args.skyVersion
        isDev = current == "dev" || String.contains "-dev" current
    in
        if not isDev && compareVersions latest current <= 0 then
            println ("Already up to date (v" ++ current ++ ").")
        else
            performUpgrade latest current


performUpgrade latest current =
    let
        _ = println ("Upgrading: v" ++ current ++ " -> v" ++ latest)
        platform = detectPlatform ()
        arch = detectArch ()
        skyBin = findSkyBin ()
    in
        if String.isEmpty skyBin then
            println "Could not find sky binary path. Please upgrade manually."
        else
            downloadAndInstall latest platform arch skyBin


downloadAndInstall latest platform arch skyBin =
    let
        skyAsset = "sky-" ++ platform ++ "-" ++ arch
        baseUrl = "https://github.com/anzellai/sky/releases/download/v" ++ latest
        url = baseUrl ++ "/" ++ skyAsset
        _ = println ("   Downloading " ++ url)
        skyResult = downloadBinary url skyBin
    in
        case skyResult of

            Ok _ ->
                let
                    _ = writeUpdateCache latest
                in
                    println ("Sky upgraded to v" ++ latest ++ " successfully!")

            Err e ->
                retrySudoDownload latest url skyBin e


retrySudoDownload latest url skyBin err =
    let
        errMsg = errorToString err
    in
        if String.contains "ermission" errMsg then
            let
                _ = println "Requires elevated permissions. Retrying with sudo..."
                sudoResult =
                    Process.run "sh"
                        [ "-c"
                        , "curl -fsSL '" ++ url ++ "' -o /tmp/sky-upgrade && chmod +x /tmp/sky-upgrade && sudo mv /tmp/sky-upgrade '" ++ skyBin ++ "'"
                        ]
            in
                case sudoResult of

                    Ok _ ->
                        let
                            _ = writeUpdateCache latest
                        in
                            println ("Sky upgraded to v" ++ latest ++ " successfully!")

                    Err e2 ->
                        println
                            ("Upgrade failed: " ++ errorToString e2 ++ "\nDownload manually from: https://github.com/anzellai/sky/releases")
        else
            println
                ("Upgrade failed: " ++ errMsg ++ "\nDownload manually from: https://github.com/anzellai/sky/releases")


downloadBinary url destPath =
    let
        tmpPath = destPath ++ ".tmp"
        result =
            Process.run "sh"
                [ "-c"
                , "curl -fsSL '" ++ url ++ "' -o '" ++ tmpPath ++ "' && chmod +x '" ++ tmpPath ++ "' && mv '" ++ tmpPath ++ "' '" ++ destPath ++ "'"
                ]
    in
        result


findSkyBin _ =
    case Process.run "which" [ "sky" ] of

        Ok p ->
            String.trim p

        Err _ ->
            ""


dirOfPath p =
    let
        parts = String.split "/" p
        dirParts = List.take (List.length parts - 1) parts
    in
        String.join "/" dirParts


detectPlatform _ =
    case Process.run "uname" [ "-s" ] of

        Ok o ->
            let
                raw = String.toLower (String.trim o)
            in
                if raw == "darwin" then
                    "darwin"
                else
                    "linux"

        Err _ ->
            "linux"


detectArch _ =
    case Process.run "uname" [ "-m" ] of

        Ok a ->
            let
                raw = String.trim a
            in
                if raw == "arm64" || raw == "aarch64" then
                    "arm64"
                else
                    "x64"

        Err _ ->
            "x64"


compareVersions : String -> String -> Int
compareVersions a b =
    let
        partsA = parseVersion a
        partsB = parseVersion b
    in
        compareVersionParts partsA partsB


parseVersion : String -> List Int
parseVersion v =
    let
        cleaned = String.replace "v" "" v
        base =
            case String.split "-" cleaned of

                first :: _ ->
                    first

                [] ->
                    cleaned
    in
        List.map parseIntOrZero (String.split "." base)


parseIntOrZero : String -> Int
parseIntOrZero s =
    case String.toInt s of

        Just n ->
            n

        Nothing ->
            0


compareVersionParts : List Int -> List Int -> Int
compareVersionParts a b =
    case a of

        [] ->
            compareVersionParts2 [] b

        x :: restA ->
            case b of

                [] ->
                    if x > 0 then
                        1
                    else
                        compareVersionParts restA []

                y :: restB ->
                    if x > y then
                        1
                    else if x < y then
                        -1
                    else
                        compareVersionParts restA restB


compareVersionParts2 a b =
    case b of

        [] ->
            0

        y :: restB ->
            if y > 0 then
                -1
            else
                compareVersionParts2 a restB


getCacheDir _ =
    case Process.run "sh" [ "-c" , "echo $HOME" ] of

        Ok home ->
            String.trim home ++ "/.sky"

        Err _ ->
            "/tmp/.sky"


getCachePath _ =
    getCacheDir () ++ "/last-update-check.json"


fetchLatestVersionFresh _ =
    let
        result =
            Process.run "sh"
                [ "-c"
                , "curl -fsSL --connect-timeout 3 https://api.github.com/repos/anzellai/sky/releases/latest 2>/dev/null | grep '\"tag_name\"' | sed 's/.*\"v\\([^\"]*\\)\".*/\\1/'"
                ]
    in
        case result of

            Ok output ->
                let
                    version = String.trim output
                    _ =
                        if not (String.isEmpty version) then
                            writeUpdateCache version
                        else
                            ()
                in
                    version

            Err _ ->
                ""


fetchLatestVersionCached _ =
    let
        cachePath = getCachePath ()
        cacheContent =
            case File.readFile cachePath of

                Ok content ->
                    String.trim content

                Err _ ->
                    ""
    in
        if String.isEmpty cacheContent then
            fetchLatestVersionSlow ()
        else
            checkCacheFreshness cachePath cacheContent


checkCacheFreshness cachePath cacheContent =
    let
        isFresh =
            case Process.run "sh"
                     [ "-c"
                     , "[ $(( $(date +%s) - $(stat -f %m '" ++ cachePath ++ "' 2>/dev/null || stat -c %Y '" ++ cachePath ++ "' 2>/dev/null || echo 0) )) -lt 86400 ] && echo fresh"
                     ] of

                Ok out ->
                    String.contains "fresh" out

                Err _ ->
                    False
    in
        if isFresh then
            cacheContent
        else
            fetchLatestVersionSlow ()


fetchLatestVersionSlow _ =
    let
        result =
            Process.run "sh"
                [ "-c"
                , "curl -fsSL --connect-timeout 3 https://api.github.com/repos/anzellai/sky/releases/latest 2>/dev/null | grep '\"tag_name\"' | sed 's/.*\"v\\([^\"]*\\)\".*/\\1/'"
                ]
    in
        case result of

            Ok output ->
                let
                    version = String.trim output
                    _ =
                        if not (String.isEmpty version) then
                            writeUpdateCache version
                        else
                            ()
                in
                    version

            Err _ ->
                ""


writeUpdateCache version =
    let
        cacheDir = getCacheDir ()
        cachePath = getCachePath ()
        _ = File.mkdirAll cacheDir
        _ = File.writeFile cachePath version
    in
        ()


checkForUpdates _ =
    let
        current = Args.skyVersion
        isDev = current == "dev" || String.contains "-dev" current
    in
        if isDev then
            ()
        else
            checkForUpdatesReal current


checkForUpdatesReal current =
    let
        latest = fetchLatestVersionCached ()
    in
        if not (String.isEmpty latest) && compareVersions latest current > 0 then
            let
                _ = println ""
                _ =
                    println
                        ("   A newer version of Sky is available: v" ++ latest ++ " (current: v" ++ current ++ ")")
                _ = println "   Run 'sky upgrade' to update."
            in
                ()
        else
            ()


cmdRemove _ =
    case Args.getArg 2 of

        Nothing ->
            println "Usage: sky remove <package>"

        Just pkg ->
            removePackage pkg


removePackage pkg =
    let
        _ = println ("Removing " ++ pkg ++ "...")
        removedFromToml = removeDepFromToml pkg
        skyDepDir = ".skydeps/" ++ pkg
        goDepDir = ".skycache/go/" ++ safePkgName pkg
        _ = Process.run "rm" [ "-rf" , skyDepDir ]
        _ = Process.run "rm" [ "-rf" , goDepDir ]
    in
        if removedFromToml then
            println ("Removed " ++ pkg)
        else
            println ("Package " ++ pkg ++ " not found in dependencies.")


safePkgName pkg =
    String.replace "-" "_"
        (String.replace "/" "_" (String.replace "." "_" pkg))


extractTomlKey line =
    let
        parts = String.split "=" line
    in
        case parts of

            key :: _ ->
                String.trim (String.replace "\"" "" (String.trim key))

            [] ->
                ""


isTomlSectionHeader trimmed =
    String.startsWith "[" trimmed


addGoDepToToml pkg version =
    case File.readFile "sky.toml" of

        Err _ ->
            ()

        Ok content ->
            let
                lines = String.split "\n" content
                depLine = pkg ++ " = \"" ++ version ++ "\""
                hasGoDeps = listContains "[go.dependencies]" lines || listContains "[\"go.dependencies\"]" lines
                alreadyHas = tomlHasDep pkg lines
            in
                if alreadyHas then
                    ()
                else if hasGoDeps then
                    let
                        newContent = insertAfterSection "[go.dependencies]" depLine lines
                    in
                        let
                            _ = File.writeFile "sky.toml" (String.join "\n" newContent)
                        in
                            ()
                else
                    let
                        newLines =
                            List.concat
                                [ lines
                                , [ "" , "[go.dependencies]" , depLine ]
                                ]
                        _ = File.writeFile "sky.toml" (String.join "\n" newLines)
                    in
                        ()


addSkyDepToToml pkg version =
    case File.readFile "sky.toml" of

        Err _ ->
            ()

        Ok content ->
            let
                lines = String.split "\n" content
                depLine = pkg ++ " = \"" ++ version ++ "\""
                hasDeps = listContains "[dependencies]" lines
                alreadyHas = tomlHasDep pkg lines
            in
                if alreadyHas then
                    ()
                else if hasDeps then
                    let
                        newContent = insertAfterSection "[dependencies]" depLine lines
                    in
                        let
                            _ = File.writeFile "sky.toml" (String.join "\n" newContent)
                        in
                            ()
                else
                    let
                        newLines =
                            List.concat
                                [ lines
                                , [ "" , "[dependencies]" , depLine ]
                                ]
                        _ = File.writeFile "sky.toml" (String.join "\n" newLines)
                    in
                        ()


listContains needle lines =
    case lines of

        [] ->
            False

        line :: rest ->
            if String.trim line == needle then
                True
            else
                listContains needle rest


tomlHasDep pkg lines =
    case lines of

        [] ->
            False

        line :: rest ->
            let
                trimmed = String.trim line
                key = extractTomlKey trimmed
            in
                if key == pkg then
                    True
                else
                    tomlHasDep pkg rest


insertAfterSection sectionName newLine lines =
    insertAfterSectionLoop sectionName newLine lines [] False


insertAfterSectionLoop sectionName newLine lines acc foundSection =
    case lines of

        [] ->
            if foundSection then
                List.append acc [ newLine ]
            else
                List.append acc [ "" , sectionName , newLine ]

        line :: rest ->
            let
                trimmed = String.trim line
            in
                if trimmed == sectionName || trimmed == "[\"go.dependencies\"]" && sectionName == "[go.dependencies]" then
                    insertAfterSectionLoop sectionName newLine rest (List.append acc [ line ]) True
                else if foundSection && isTomlSectionHeader trimmed then
                    List.concat [ acc , [ newLine , "" ] , [ line ] , rest ]
                else
                    insertAfterSectionLoop sectionName newLine rest (List.append acc [ line ]) foundSection


removeDepFromToml pkg =
    case File.readFile "sky.toml" of

        Err _ ->
            False

        Ok content ->
            let
                lines = String.split "\n" content
                filtered = removeDepLines pkg lines
                newContent = String.join "\n" filtered
            in
                if newContent == content then
                    False
                else
                    let
                        _ = File.writeFile "sky.toml" newContent
                    in
                        True


removeDepLines pkg lines =
    case lines of

        [] ->
            []

        line :: rest ->
            let
                trimmed = String.trim line
                key = extractTomlKey trimmed
            in
                if key == pkg && String.contains "=" trimmed then
                    removeDepLines pkg rest
                else
                    line :: removeDepLines pkg rest


cmdFmt _ =
    let
        filePath =
            case Args.getArg 2 of

                Just f ->
                    f

                Nothing ->
                    "src/Main.sky"
        useStdin = filePath == "--stdin" || filePath == "-"
    in
        if useStdin then
            fmtStdin ()
        else
            case File.readFile filePath of

                Err e ->
                    let
                        _ = println ("Cannot read: " ++ filePath)
                    in
                        Process.exit 1

                Ok source ->
                    fmtFileSource filePath source


fmtFileSource filePath source =
    let
        lexResult = Lexer.lex source
    in
        case Parser.parse lexResult.tokens of

            Err e ->
                let
                    _ = println ("Parse error: " ++ e)
                in
                    Process.exit 1

            Ok mod ->
                let
                    formatted = Format.formatModule mod
                    withComments =
                        reinsertComments source formatted
                    _ = File.writeFile filePath withComments
                    _ = println ("Formatted: " ++ filePath)
                in
                    ()


reinsertComments : String -> String -> String
reinsertComments original formatted =
    let
        commentGroups = collectCommentGroups (String.split "\n" original) [] []
        fmtLines = String.split "\n" formatted
    in
        String.join "\n" (insertCommentGroups commentGroups fmtLines [])


isCommentLine : String -> Bool
isCommentLine trimmed =
    String.startsWith "--" trimmed || String.startsWith "{-" trimmed


collectCommentGroups : (List String) -> (List String) -> (List (List String, String)) -> List (List String, String)
collectCommentGroups lines currentComments acc =
    case lines of

        [  ] ->
            if List.isEmpty currentComments then
                List.reverse acc
            else
                List.reverse ((List.reverse currentComments, "") :: acc)

        line :: rest ->
            let
                trimmed = String.trim line
            in
                if isCommentLine trimmed then
                    collectCommentGroups rest (line :: currentComments) acc
                else if String.isEmpty trimmed then
                    collectCommentGroups rest currentComments acc
                else if not (List.isEmpty currentComments) then
                    let
                        anchorWord = extractAnchorWord trimmed
                    in
                        collectCommentGroups rest []
                            ((List.reverse currentComments, anchorWord) :: acc)
                else
                    collectCommentGroups rest [] acc


extractAnchorWord : String -> String
extractAnchorWord line =
    case String.split " " line of

        word :: _ ->
            word

        [  ] ->
            line


insertCommentGroups : (List (List String, String)) -> (List String) -> (List String) -> List String
insertCommentGroups groups fmtLines acc =
    case groups of

        [  ] ->
            List.append acc fmtLines

        group :: restGroups ->
            let
                comments = fst group
                anchor = snd group
            in
                if String.isEmpty anchor then
                    insertCommentGroups restGroups fmtLines
                        (List.append acc comments)
                else
                    insertBeforeAnchorOnce comments anchor restGroups fmtLines
                        acc


insertBeforeAnchorOnce : (List String) -> String -> (List (List String, String)) -> (List String) -> (List String) -> List String
insertBeforeAnchorOnce comments anchor restGroups fmtLines acc =
    case fmtLines of

        [  ] ->
            insertCommentGroups restGroups [] (List.append acc comments)

        fmtLine :: fmtRest ->
            if String.startsWith anchor (String.trim fmtLine) then
                insertCommentGroups restGroups fmtRest
                    (List.concat [ acc , comments , [ fmtLine ] ])
            else
                insertBeforeAnchorOnce comments anchor restGroups fmtRest
                    (List.append acc [ fmtLine ])


fmtStdin _ =
    case Io.readAllStdin () of

        Ok source ->
            fmtStdinSource source

        Err e ->
            let
                _ = Io.writeStderr ("Cannot read stdin")
            in
                Process.exit 1


fmtStdinSource source =
    let
        lexResult = Lexer.lex source
    in
        case Parser.parse lexResult.tokens of

            Err e ->
                let
                    _ = Io.writeStderr ("Parse error: " ++ e)
                in
                    Process.exit 1

            Ok mod ->
                Io.writeStdout
                    (reinsertComments source (Format.formatModule mod))


cmdHelp _ =
    let
        _ = println ("Sky Programming Language " ++ Args.skyVersion)
        _ = println ""
        _ = println "Usage: sky <command> [args]"
        _ = println ""
        _ = println "Commands:"
        _ = println "  init [name]     Create a new Sky project"
        _ = println "  build [file]    Compile to Go binary"
        _ = println "  run [file]      Build and run"
        _ = println "  check [file]    Type-check only"
        _ = println "  fmt [file]      Format Sky source code"
        _ = println "  add <package>   Add Go or Sky dependency"
        _ =
            println
                "  install         Install all dependencies + generate bindings"
        _ = println "  remove <pkg>    Remove a dependency"
        _ = println "  update          Update sky.toml dependencies to latest"
        _ = println "  upgrade         Upgrade Sky compiler to latest release"
        _ = println "  clean           Remove build artifacts"
        _ = println "  version         Show version"
    in
        ()


cmdClean _ =
    let
        _ = Process.run "rm" [ "-rf" , "dist" ]
        _ = Process.run "rm" [ "-rf" , "sky-out" ]
    in
        println "Cleaned."
