module Std.Sub exposing (Sub, SubNone, SubTimer, SubBatch, none, batch)

-- Sub msg represents a subscription to external events.

type Sub msg
    = SubNone
    | SubTimer Int msg
    | SubBatch (List (Sub msg))

none : Sub msg
none =
    SubNone

batch : List (Sub msg) -> Sub msg
batch subs =
    SubBatch subs
