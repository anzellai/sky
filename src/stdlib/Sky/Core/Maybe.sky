
module Sky.Core.Maybe exposing (..)

type Maybe a
    = Just a
    | Nothing

foreign import "sky_wrappers" exposing (Sky_maybe_WithDefault, Sky_maybe_Map, Sky_maybe_AndThen)

withDefault fallback value =
    Sky_maybe_WithDefault fallback value

map fn maybe =
    Sky_maybe_Map fn maybe

andThen fn maybe =
    Sky_maybe_AndThen fn maybe
