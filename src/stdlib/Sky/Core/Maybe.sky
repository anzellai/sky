
module Sky.Core.Maybe exposing (..)

type Maybe a
    = Just a
    | Nothing

withDefault fallback value =
    case value of
        Just v ->
            v
        Nothing ->
            fallback

map fn maybe =
    case maybe of
        Just value ->
            Just (fn value)
        Nothing ->
            Nothing

andThen fn maybe =
    case maybe of
        Just value ->
            fn value
        Nothing ->
            Nothing
