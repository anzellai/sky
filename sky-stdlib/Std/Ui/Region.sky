module Std.Ui.Region exposing (mainContent, navigation, footer, aside, heading, label, announce, announceUrgently)

-- Std.Ui.Region — semantic landmarks + accessibility helpers.
--
-- Each helper attaches a Description to an Element. The Std.Ui
-- renderer dispatches the appropriate semantic HTML tag from the
-- Description (DescMain → <main>, DescNavigation → <nav>,
-- DescContentInfo → <footer>, DescComplementary → <aside>,
-- DescHeading n → <hN>) and emits matching aria-* attributes for the
-- live-region / labelling helpers (DescLabel → aria-label,
-- DescLivePolite → aria-live="polite", DescLiveAssertive →
-- aria-live="assertive").
--
-- For a screen-reader-friendly app, wrap your top-level layout
-- with `Region.mainContent`, your nav bar with `Region.navigation`,
-- your sidebar with `Region.aside`, and use `Region.heading n` on
-- text elements that act as section headings.

import Sky.Core.Prelude exposing (..)
import Std.Ui exposing (Description, Attribute, describe, descMain, descNavigation, descContentInfo, descComplementary, descHeading, descLabel, descLivePolite, descLiveAssertive)


-- Mark an element as the main content region of the page.
-- Renders as `<main>`.
mainContent : Attribute msg
mainContent = describe descMain


-- Navigation landmark — sidebar links, top nav bar, footer-nav, etc.
-- Renders as `<nav>`.
navigation : Attribute msg
navigation = describe descNavigation


-- Page / section footer landmark. Renders as `<footer>`.
footer : Attribute msg
footer = describe descContentInfo


-- Complementary content landmark — sidebars, related-links panels,
-- pull-quotes, secondary navigation. Renders as `<aside>`.
aside : Attribute msg
aside = describe descComplementary


-- Section heading — `Region.heading 1` renders as `<h1>`,
-- `Region.heading 2` as `<h2>`, etc. Headings 7+ collapse to
-- `<h6>` (HTML's deepest heading level).
heading : Int -> Attribute msg
heading n = describe (descHeading n)


-- Visually hidden label, used by screen readers as the accessible
-- name for the element. Emits `aria-label="<text>"`.
label : String -> Attribute msg
label text = describe (descLabel text)


-- Announce updates inside this element to assistive technology
-- "politely" — the screen reader will queue the change and read it
-- when the user pauses. Use for non-urgent status updates ("Saved",
-- "Loading 12/100", chat notifications). Emits aria-live="polite".
announce : Attribute msg
announce = describe descLivePolite


-- Announce updates inside this element urgently — the screen reader
-- interrupts the user with the change. Use sparingly: error toasts,
-- critical alerts, anything safety-relevant. Emits
-- aria-live="assertive".
announceUrgently : Attribute msg
announceUrgently = describe descLiveAssertive
